@model IEnumerable<LVTNWEBGIAYDEP.Models.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách tài khoản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách tài khoản Hoạt Động</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>
    <style>
        .form-check {
            display: flex;
            align-items: center; /* Căn giữa theo chiều dọc */
            justify-content: flex-start; /* Căn lề trái theo chiều ngang */
            margin-bottom: 10px; /* Khoảng cách giữa các radio */
        }

        .form-check-input {
            margin-right: 10px; /* Khoảng cách giữa nút radio và label */
        }


        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }

        .container {
            margin-top: 40px;
            margin-bottom: 40px;
        }

        .table {
            border: 1px solid #dee2e6;
            border-radius: 10px;
            overflow: hidden;
        }

            .table th {
                background-color: #007bff;
                color: white;
                text-align: center;
            }

            .table td {
                text-align: center;
            }

        .btn-action {
            margin: 5px;
            transition: all 0.3s ease-in-out;
        }

            .btn-action:hover {
                transform: scale(1.1);
            }

        .message-box {
            margin-bottom: 20px;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
        }

            .message-box.success {
                background-color: #d4edda;
                color: #155724;
            }

            .message-box.error {
                background-color: #f8d7da;
                color: #721c24;
            }

        .modal-content {
            border-radius: 15px;
        }
    </style>
</head>

<body>
    <div class="container">
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="message-box success">
                <i class="fas fa-check-circle"></i> @ViewBag.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="message-box error">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.ErrorMessage
            </div>
        }

        <h1 class="text-center mb-4">Danh sách tài khoản hoạt động</h1>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Tài khoản</th>
                   
                    <th>Trạng thái</th>
                    <th>Phân quyền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    @if(item.trangThai == "Hoạt Động")
                    {
                    <tr>
                        <td>@item.HoTen</td>
                        <td>@item.TaiKhoan1</td>
                           

                        <td>
                            <span class="badge @(@item.trangThai == "Hoạt Động" ? "bg-success" : "bg-secondary")">
                                @item.trangThai
                            </span>
                        </td>
                        <td>@item.phanQuyen</td>
                        <td>
                            <form method="post" asp-action="TrangThaiTaiKhoan" style="display: inline;">
                                <input type="hidden" name="tk" value="@item.TaiKhoan1" />
                                <button class="btn btn-warning btn-sm btn-action">
                                    <i class="fas fa-ban"></i> Đóng băng
                                </button>
                            </form>
                                <button class="btn btn-info btn-sm btn-action" onclick="showPhanQuyenModal('@item.TaiKhoan1')">

                                    <i class="fas fa-user-cog"></i> Phân quyền
                                </button>
                                <div id="modalPhanQuyen" class="modal fade" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Phân quyền tài khoản: @item.TaiKhoan1</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <form id="phanQuyenForm" method="post" asp-action="PhanQuyen">
                                                    <input type="hidden" id="modalTaiKhoan" name="tk" />
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="User" id="roleUser"
                                                        @(item.phanQuyen == "User" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleUser">User</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="Admin" id="roleAdmin"
                                                        @(item.phanQuyen == "Admin" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleAdmin">Admin</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="Quản trị viên" id="roleQTV"
                                                        @(item.phanQuyen == "Quản trị viên" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleQTV">Quản trị viên</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="Nhân viên bán hàng" id="roleNVBH"
                                                        @(item.phanQuyen == "Nhân viên bán hàng" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleNVBH">Nhân viên bán hàng</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="Nhân viên quản lý sản phẩm" id="roleNVQLSP"
                                                        @(item.phanQuyen == "Nhân viên quản lý sản phẩm" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleNVQLSP">Nhân viên quản lý sản phẩm</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="pq" value="Nhân viên chăm sóc khách hàng" id="roleNVCSKH"
                                                        @(item.phanQuyen == "Nhân viên chăm sóc khách hàng" ? "checked" : "") />
                                                        <label class="form-check-label" for="roleNVCSKH">Nhân viên chăm sóc khách hàng</label>
                                                    </div>

                                                    <!-- Thêm các tùy chọn khác -->
                                                </form>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                                <button type="submit" class="btn btn-primary" form="phanQuyenForm">Cập nhật</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                        
                                <form id="formXoaTaiKhoan" method="post" asp-action="xoaTaiKhoanhd" style="display:none;">
                                    <input type="hidden" id="xoatk" name="xoatk" value="@item.TaiKhoan1" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash-alt"></i> Xóa
                                    </button>
                                </form>
                                <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete('@item.TaiKhoan1')">
                                    <i class="fas fa-trash-alt"></i> Xóa
                                </button>
                                <form id="updatePasswordForm" method="post" style="display: inline;">
                                    <input type="hidden" name="tk" value="@item.TaiKhoan1" />
                                    <input type="hidden" name="oldMatKhau" value="@item.MatKhau" />

                                    <!-- Nút mở modal -->
                                    <button type="button" class="btn btn-success btn-sm btn-action" onclick="showUpdatePasswordModal('@item.TaiKhoan1', '@item.MatKhau')">
                                        <i class="fas fa-check-circle"></i> Cập nhật mật khẩu
                                    </button>
                                </form>

                                <!-- Modal nhập mật khẩu mới -->
                                <div id="updatePasswordModal" class="modal fade" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Cập nhật mật khẩu cho tài khoản: <span id="taiKhoanLabel"></span></h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <form id="modalUpdatePasswordForm" method="post" asp-action="capNhatMK">
                                                    <input type="hidden" id="tk" name="tk" />
                                                    <input type="hidden" id="oldMatKhau" name="oldMatKhau" />
                                                    <div class="form-group">
                                                        <label for="newMatKhau">Mật khẩu mới</label>
                                                        <input type="password" class="form-control" id="newMatKhau" name="newMatKhau" required />
                                                    </div>
                                                </form>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                                <button type="button" class="btn btn-primary" onclick="submitPasswordForm()">Cập nhật</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                           



                           
                            </td>
                    </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Modal phân quyền -->
 

    <script>
        function showPhanQuyenModal(taiKhoan) {
            document.getElementById("modalTaiKhoan").value = taiKhoan;
            new bootstrap.Modal(document.getElementById("modalPhanQuyen")).show();
        }

      
    </script>
    <script>
        function confirmDelete(taiKhoan1) {
            if (window.confirm("Bạn có thực sự muốn xoá tài khoản này không?")) {
                // Nếu người dùng chọn "Ok", gán giá trị vào input và submit form
                document.getElementById("xoatk").value = taiKhoan1;
                document.getElementById("formXoaTaiKhoan").submit(); // Submit form
            }
        }
    </script>
    <script>
        // Hàm mở modal và điền thông tin tài khoản
        function showUpdatePasswordModal(taiKhoan, oldMatKhau) {
            document.getElementById("tk").value = taiKhoan;
            document.getElementById("oldMatKhau").value = oldMatKhau;
            document.getElementById("taiKhoanLabel").textContent = taiKhoan;
            new bootstrap.Modal(document.getElementById("updatePasswordModal")).show();
        }

        // Hàm kiểm tra mật khẩu mới và gửi form
        function submitPasswordForm() {
            const newMatKhau = document.getElementById("newMatKhau").value;
            if (!newMatKhau) {
                alert("Vui lòng nhập mật khẩu mới!");
            } else {

                // Gửi form sau khi kiểm tra
                document.getElementById("modalUpdatePasswordForm").submit();
            }
        }
    </script>

    
</body>

</html>
