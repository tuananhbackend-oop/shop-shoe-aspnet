@model IEnumerable<LVTNWEBGIAYDEP.Models.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách tài khoản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách tài khoản đóng băng</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>



    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }

        .container {
            margin-top: 40px;
            margin-bottom: 40px;
        }

        .table {
            border: 1px solid #dee2e6;
            border-radius: 10px;
            overflow: hidden;
        }

            .table th {
                background-color: #007bff;
                color: white;
                text-align: center;
            }

            .table td {
                text-align: center;
            }

        .btn-action {
            margin: 5px;
            transition: all 0.3s ease-in-out;
        }

            .btn-action:hover {
                transform: scale(1.1);
            }

        .message-box {
            margin-bottom: 20px;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
        }

            .message-box.success {
                background-color: #d4edda;
                color: #155724;
            }

            .message-box.error {
                background-color: #f8d7da;
                color: #721c24;
            }

        .modal-content {
            border-radius: 15px;
        }
    </style>
</head>

<body>
    <div class="container">
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="message-box success">
                <i class="fas fa-check-circle"></i> @ViewBag.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="message-box error">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.ErrorMessage
            </div>
        }

        <h1 class="text-center mb-4">Danh sách tài khoản đóng băng</h1>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Tài khoản</th>
                    
                    <th>Trạng thái</th>
                    <th>Phân quyền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    @if (item.trangThai == "Đóng Băng")
                    {
                        <tr>
                            <td>@item.HoTen</td>
                            <td>@item.TaiKhoan1</td>
                      
                            <td>
                                <span class="badge @(@item.trangThai == "Hoạt Động" ? "bg-success" : "bg-secondary")">
                                    @item.trangThai
                                </span>
                            </td>
                            <td>@item.phanQuyen</td>
                            <td>
                                <form method="post" asp-action="TrangThaiTaiKhoan" style="display: inline;">
                                    <input type="hidden" name="tk" value="@item.TaiKhoan1" />
                                    <button class="btn btn-success btn-sm btn-action">
                                        <i class="fas fa-check-circle"></i> Kích hoạt tài khoản
                                    </button>
                                </form>

                                <form id="formXoaTaiKhoan" method="post" asp-action="xoaTaiKhoandb" style="display:none;">
                                    <input type="hidden" id="xoatk" name="xoatk" value="@item.TaiKhoan1" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash-alt"></i> Xóa
                                    </button>
                                </form>
                                <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete('@item.TaiKhoan1')">
                                    <i class="fas fa-trash-alt"></i> Xóa
                                </button>
                               
                              

                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Modal phân quyền -->
    

    <script>
        function confirmDelete(taiKhoan1) {
            if (window.confirm("Bạn có thực sự muốn xoá tài khoản này không?")) {
                // Nếu người dùng chọn "Ok", gán giá trị vào input và submit form
                document.getElementById("xoatk").value = taiKhoan1;
                document.getElementById("formXoaTaiKhoan").submit(); // Submit form
            }
        }
    </script>

  





</body>

</html>
