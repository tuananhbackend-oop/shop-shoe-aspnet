
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
	<title></title>
	<style>


		.table-header {
			display: flex; /* Đảm bảo các phần tử con xếp ngang nhau */
			justify-content: space-between; /* Giãn đều các phần tử */
			padding: 10px; /* Tạo khoảng cách bên trong */
			background-color: #2c3e50; /* Màu nền tiêu đề */
			color: white; /* Màu chữ */
			font-weight: bold; /* Chữ đậm */
			border-radius: 8px 8px 0 0; /* Bo tròn góc trên của bảng */
		}

			.table-header .table-cell {
				flex: 1; /* Mỗi ô có độ rộng bằng nhau */
				text-align: center; /* Căn giữa chữ */
				padding: 8px; /* Tạo khoảng cách trong ô */
				font-size: 14px; /* Kích thước chữ */
			}

		.table-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 10px;
			border-bottom: 1px solid #e1e1e1;
			background-color: #fff;
		}

		.table-cell {
			flex: 1;
			padding: 8px;
			text-align: center;
			font-size: 14px;
			word-break: break-word; /* Ngăn tràn nội dung */
		}

		.header-cell {
			font-weight: bold;
			background-color: #2c3e50;
			color: white;
		}
		/* General container style */
		#ega-account {
			font-family: Arial, sans-serif;
			background-color: #f7f7f7;
			padding: 20px;
		}

		.ega-container {
			max-width: 1200px;
			margin: 0 auto;
		}





		.table-body {
			background-color: white;
			border-radius: 8px;
			box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
			overflow: hidden;
		}

		.actions {
			display: flex;
			gap: 8px; /* Khoảng cách giữa các nút */
			justify-content: center; /* Căn giữa trong ô */
			align-items: center; /* Căn giữa theo chiều dọc */
		}

		.inline-form {
			display: inline-block; /* Đảm bảo form và nút không bị xuống dòng */
			margin: 0; /* Loại bỏ khoảng cách mặc định của form */
		}

		.btn {
			padding: 8px 15px;
			border-radius: 4px;
			border: none;
			cursor: pointer;
			font-size: 14px;
			transition: background-color 0.3s ease;
		}

		.btn-primary {
			background-color: #3498db;
			color: white;
		}

		.btn-danger {
			background-color: #e74c3c;
			color: white;
		}

		.btn:hover {
			opacity: 0.8;
		}

		.page-title {
			text-align: center;
			margin-bottom: 20px;
			color: #2c3e50;
		}

		.separator {
			margin-top: 15px;
			border: 0;
			border-top: 1px solid #e1e1e1;
		}

		.user_box_title {
			font-size: 18px;
			font-weight: bold;
			margin-bottom: 10px;
		}

		.user_box_content {
			padding: 15px;
			background-color: white;
			box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.1);
			border-radius: 8px;
		}

		.detail-item {
			margin-bottom: 10px;
		}

		.detail-key {
			font-weight: bold;
		}

		.detail-value {
			margin-left: 5px;
		}

		.detail__wrap {
			margin-top: 20px;
		}

		.delete-form {
			margin-left: 10px;
		}

		.btn-logout {
			display: inline-block;
			padding: 8px 15px;
			background-color: #f39c12;
			color: white;
			border-radius: 4px;
			text-decoration: none;
		}

			.btn-logout:hover {
				opacity: 0.8;
			}
	</style>
	<style>
		.modal-content div {
			text-align: left; /* Đảm bảo toàn bộ nội dung trong div được căn trái */
		}

			.modal-content div label {
				display: inline-block; /* Các radio button và nhãn nằm ngang */
				margin-right: 10px; /* Khoảng cách giữa các radio và nhãn */
				margin-bottom: 10px; /* Khoảng cách giữa các radio */
			}

			.modal-content div input[type="radio"] {
				margin-right: 5px; /* Khoảng cách giữa radio và nhãn */
			}


		textarea {
			width: 100%;
			height: 80px;
			margin-top: 10px;
			margin-bottom: 20px;
		}

			textarea#other-reason {
				display: none;
			}

		.modal {
			display: none;
			position: fixed;
			z-index: 1000;
			left: 0;
			top: 0;
			width: 100%;
			height: 100%;
			overflow: auto;
			background-color: rgba(0, 0, 0, 0.5);
		}

		.modal-content {
			background-color: #fff;
			margin: 15% auto;
			padding: 20px;
			border: 1px solid #888;
			width: 50%;
			border-radius: 8px;
		}

		.close {
			color: #aaa;
			float: right;
			font-size: 28px;
			font-weight: bold;
			cursor: pointer;
		}

		textarea {
			width: 100%;
			height: 80px;
			margin-top: 10px;
			margin-bottom: 20px;
		}
	</style>
	<style>

		.actions {
			display: flex;
			gap: 12px; /* Tăng khoảng cách giữa các nút */
			justify-content: center; /* Căn giữa các nút trong ô */
			align-items: center; /* Căn giữa theo chiều dọc */
			flex-wrap: wrap; /* Cho phép các nút xuống dòng nếu không đủ chỗ */
		}

		.inline-form {
			display: flex; /* Đảm bảo các phần tử con xếp ngang */
			align-items: center; /* Căn giữa nội dung */
			justify-content: center; /* Căn giữa nội dung trong form */
			margin: 0; /* Loại bỏ khoảng cách mặc định của form */
		}

		.btn {
			padding: 10px 20px; /* Tăng kích thước nút */
			border-radius: 4px;
			border: none;
			cursor: pointer;
			font-size: 14px;
			min-width: 120px; /* Đặt chiều rộng tối thiểu để nút không bị bó hẹp */
			transition: background-color 0.3s ease;
			text-align: center; /* Đảm bảo chữ trong nút căn giữa */
		}

		.btn-primary {
			background-color: #3498db;
			color: white;
		}

		.btn-danger {
			background-color: #e74c3c;
			color: white;
		}

		.btn:hover {
			opacity: 0.8;
		}

	</style>

</head>
<body class="template_customers" id="ega-fashion">
	<div id="ega-account">
		<div class="ega-container">
			<div class="ega-row">
				<div class="acc-box ega-16col-5 ega-col-lg-4 ega-col-12">
					<div class="account-detail user_box">
						<div class="user_box_title">Thông tin tài khoản</div>
						<div class="user_box_content">
							<div class="detail__wrap">
								<div class="detail-item">
									<span class="detail-key">Họ tên</span><span class="detail-value">: @Model.HoTen</span>
								</div>
								<div class="detail-item">
									<span class="detail-key">Tài khoản</span><span class="detail-value">: @Model.TaiKhoan1</span>
								</div>
								<div class="detail-item">
									<a href="@Url.Action("Logout", "DangNhap")" class="btn btn-logout">Đăng xuất</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<h1 class="page-title">Đơn hàng của bạn</h1>

	<div class="table-header">
		<div class="table-cell header-cell">Số Điện Thoại</div>
		<div class="table-cell header-cell">Địa Chỉ</div>
		<div class="table-cell header-cell">Thanh Toán</div>
		<div class="table-cell header-cell">Đơn Mua</div>
		<div class="table-cell header-cell">Hành động</div>
	</div>

	<div class="table-body">
		@foreach (var item in (List<DonHang>)ViewData["Orders"])
		{
			<div>
				@if (@item.trangThai != "Đã Huỷ" && @item.trangThai != "Hoàn Tất")
				{
	
			string idDiv = "div" + item.iDDonHang;
			string idInput = "input" + item.iDDonHang;
			<div class="table-row">
				<div class="table-cell">@item.SoDienThoai</div>
				<div class="table-cell">@item.DiaChi</div>
				<div class="table-cell">@item.thanhToan</div>
				<div class="table-cell">@item.trangThai</div>
				<div class="table-cell actions">
				
					<input type="button" id="@idInput" class="btn btn-primary" onclick="xemChiTietHD('@item.iDDonHang')" value="Xem chi tiết"></input>
					@if (@item.trangThai == "Chờ xác nhận")
					{
								<form id="deleteForm-@item.iDDonHang" asp-action="xoaDonHang" method="post" class="delete-form inline-form">
									<input type="hidden" id="idhd-@item.iDDonHang" name="idhd" value="@item.iDDonHang" />
									<input type="hidden" id="LyDo-@item.iDDonHang" name="LyDo" />
									<button type="button" class="btn btn-danger" onclick="showDeleteModal('@item.iDDonHang')">Huỷ đơn hàng</button>
								</form>

								<!-- Modal nhập lý do -->
								<div id="modal-@item.iDDonHang" class="modal">
									<div class="modal-content">
										<span id="close-@item.iDDonHang" class="close">&times;</span>
										<h3>Nhập lý do hủy đơn hàng</h3>
										<div>
											<label><input type="radio" name="reason-options-@item.iDDonHang" value="Tôi muốn cập nhật địa chỉ/số điện thoại"> Tôi muốn cập nhật địa chỉ/số điện thoại</label><br>
											<label><input type="radio" name="reason-options-@item.iDDonHang" value="Người bán không trả lời thắc mắc/yêu cầu của tôi"> Người bán không trả lời thắc mắc/yêu cầu của tôi</label><br>
											<label><input type="radio" name="reason-options-@item.iDDonHang" value="Thay đổi đơn hàng"> Thay đổi đơn hàng</label><br>
											<label><input type="radio" name="reason-options-@item.iDDonHang" value="Khác" onclick="toggleOtherReason('@item.iDDonHang')"> Khác</label><br>
											<textarea id="other-reason-@item.iDDonHang" style="display:none;" placeholder="Nhập lý do khác..."></textarea>
										</div>
										<br />
										<button id="confirm-@item.iDDonHang" class="btn btn-primary">Xác nhận</button>
									</div>
								</div>
					}@if (@item.trangThai == "Đã nhận được hàng")
					{
						<form id="deleteForm" asp-action="hoanTat" method="post" class="inline-form">
									<input type="hidden" id="idhd" name="idhd" value="@item.iDDonHang" />
									<button type="button" class="btn btn-danger" onclick="confirmDelete('@item.iDDonHang')">Đã nhận đơn hàng</button>
						</form>

								<form id="khongNhanHang-@item.iDDonHang" asp-action="khongNhanHang" method="post">
									<input type="hidden" id="idhd-@item.iDDonHang" name="idhd" value="@item.iDDonHang" />
									<input type="hidden" id="LyDo-@item.iDDonHang" name="LyDo" />
									<button type="button" class="btn btn-danger" onclick="showKhongNhanHangModal('@item.iDDonHang')">Không nhận hàng</button>
								</form>

								<!-- Modal Không Nhận Hàng -->
								<div id="modal-khongNhanHang" class="modal">
									<div class="modal-content">
										<span id="close-modal" class="close">&times;</span>
										<h4>Lý do không nhận hàng</h4>
										<div>
											<label>
												<input type="radio" name="reason-options" value="Lỗi sản phẩm"> Lỗi sản phẩm
											</label>
											<label>
												<input type="radio" name="reason-options" value="Tôi muốn sản phẩm khác"> Tôi muốn sản phẩm khác
											</label>
											<label>
												<input type="radio" name="reason-options" value="Không nhận"> Không nhận
											</label>
											<label>
												<input type="radio" name="reason-options" value="Khác"> Khác
											</label>
											<textarea id="other-reason" placeholder="Nhập lý do khác..." style="display: none;"></textarea>
										</div>
										<div id="error-message" style="color: red; margin-top: 10px;"></div>
										<button id="confirm-modal" class="btn btn-primary">Xác nhận</button>
										<button id="close-modal-btn" class="btn btn-secondary">Đóng</button>
									</div>
								</div>						
					}
											
				
				</div>
			</div>
			<div id="@idDiv" class="details-container"></div>
			<hr class="separator" />
				}
			</div>
		}
	</div>
		<script>
		function confirmDelete(SoDienThoai) {
			if (window.confirm("Bạn đã nhận được đơn hàng?")) {
				document.getElementById("idhd").value = SoDienThoai;
				document.getElementById("deleteForm").submit();
			}
		}
	</script>
	





	<!-- JavaScript -->

	<script>
		function showDeleteModal(phoneNumber) {
			const modalId = `modal-${phoneNumber}`;
			const reasonInputId = `LyDo-${phoneNumber}`;

			// Hiển thị modal
			const modal = document.getElementById(modalId);
			if (modal) {
				modal.style.display = "block";
			}

			// Khi nhấn xác nhận, lưu lý do vào input hidden
			document.getElementById(`confirm-${phoneNumber}`).onclick = function () {
				// Lấy lý do từ radio hoặc textarea
				const reasonOptions = document.getElementsByName(`reason-options-${phoneNumber}`);
				let reason = "";
				for (const option of reasonOptions) {
					if (option.checked) {
						reason = option.value;
						break;
					}
				}

				// Nếu chọn "Khác", lấy lý do từ textarea
				if (reason === "Khác") {
					const otherReason = document.getElementById(`other-reason-${phoneNumber}`).value.trim();
					if (!otherReason) {
						alert("Vui lòng nhập lý do hủy đơn hàng.");
						return;
					}
					reason = otherReason;
				}

				document.getElementById(reasonInputId).value = reason;

				// Submit form
				document.getElementById(`deleteForm-${phoneNumber}`).submit();
			};

			// Đóng modal
			document.getElementById(`close-${phoneNumber}`).onclick = function () {
				modal.style.display = "none";
			};
		}

		function toggleOtherReason(phoneNumber) {
			const otherReasonTextarea = document.getElementById(`other-reason-${phoneNumber}`);
			otherReasonTextarea.style.display = "block";
		}

	</script>


	<script>
		
	

		function xemChiTietHD(id) {
			const xhttp = new XMLHttpRequest();
			xhttp.onload = function () {
				// Kiểm tra nếu giá trị của nút là "Xem chi tiết"
				if (document.getElementById("input" + id).value == "Xem chi tiết") {
					document.getElementById("div" + id).innerHTML = xhttp.responseText;
					// Thay đổi giá trị của nút thành "Đóng chi tiết"
					document.getElementById("input" + id).value = "Đóng chi tiết";
				} else {
					// Nếu giá trị của nút là "Đóng chi tiết", thay đổi lại về "Xem chi tiết"
					document.getElementById("input" + id).value = "Xem chi tiết";
					// Xóa nội dung hiển thị chi tiết
					document.getElementById("div" + id).innerHTML = "";
				}
			}
			const url = "/QLDonHang/hienThiChiTietHD/" + id;
			xhttp.open("GET", url);
			xhttp.send();
		}
	</script>
	<style>
		.modal {
			display: none;
			position: fixed;
			z-index: 1000;
			left: 0;
			top: 0;
			width: 100%;
			height: 100%;
			overflow: auto;
			background-color: rgba(0, 0, 0, 0.5);
		}

		.modal-content {
			background-color: #fff;
			margin: 15% auto;
			padding: 20px;
			border: 1px solid #888;
			width: 50%;
			border-radius: 8px;
		}

		.close {
			color: #aaa;
			float: right;
			font-size: 28px;
			font-weight: bold;
			cursor: pointer;
		}

		textarea {
			width: 100%;
			height: 80px;
			margin-top: 10px;
			margin-bottom: 20px;
		}

		.modal-content div {
			text-align: left;
		}

			.modal-content div label {
				display: block; /* Xếp các radio button theo chiều dọc */
				margin-bottom: 10px; /* Khoảng cách giữa các radio button */
			}

			.modal-content div input[type="radio"] {
				margin-right: 10px; /* Khoảng cách giữa radio và nhãn */
			}


	</style>
	<script>
		function showKhongNhanHangModal(phoneNumber) {
			// Lưu phoneNumber cho modal
			const modal = document.getElementById('modal-khongNhanHang');
			const confirmButton = document.getElementById('confirm-modal');
			const closeButton = document.getElementById('close-modal');
			const closeModalBtn = document.getElementById('close-modal-btn');

			// Hiển thị modal
			modal.style.display = 'block';

			// Xử lý khi chọn "Khác" để hiện textarea
			document.querySelectorAll('input[name="reason-options"]').forEach(option => {
				option.addEventListener('change', function () {
					const otherReasonTextarea = document.getElementById('other-reason');
					if (this.value === 'Khác') {
						otherReasonTextarea.style.display = 'block';
					} else {
						otherReasonTextarea.style.display = 'none';
					}
				});
			});

			// Khi nhấn Xác nhận
			confirmButton.onclick = function () {
				// Lấy lý do
				const reasonOptions = document.getElementsByName('reason-options');
				let reason = '';
				for (const option of reasonOptions) {
					if (option.checked) {
						reason = option.value;
						break;
					}
				}

				// Nếu chọn "Khác", kiểm tra và lấy giá trị từ textarea
				if (reason === 'Khác') {
					const otherReason = document.getElementById('other-reason').value.trim();
					if (!otherReason) {
						document.getElementById('error-message').textContent = "Vui lòng nhập lý do hủy đơn hàng.";
						return;
					}
					reason = otherReason;
				}

				if (!reason) {
					document.getElementById('error-message').textContent = "Vui lòng chọn lý do.";
					return;
				}

				// Gán giá trị lý do vào input hidden
				document.getElementById(`LyDo-${phoneNumber}`).value = reason;

				// Submit form
				document.getElementById(`khongNhanHang-${phoneNumber}`).submit();
			};

			// Khi nhấn đóng
			closeButton.onclick = closeModal;
			closeModalBtn.onclick = closeModal;

			function closeModal() {
				modal.style.display = 'none';
				document.getElementById('error-message').textContent = '';
				document.getElementById('other-reason').style.display = 'none';
			}
		}

		// Đóng modal khi nhấn bên ngoài
		window.onclick = function (event) {
			const modal = document.getElementById('modal-khongNhanHang');
			if (event.target === modal) {
				modal.style.display = 'none';
			}
		};
	</script>



</body>




</html>



