@model List<LVTNWEBGIAYDEP.Models.SanPham>

@{
    ViewData["Title"] = "SanPham";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý sản phẩm</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome (Icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
            font-size: 14px;
        }

        .page-title {
            background-color: #007bff;
            color: white;
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .table-wrapper {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .table {
            font-size: 14px;
            margin-bottom: 0;
        }

            .table thead {
                background-color: #343a40;
                color: white;
            }

            .table tbody tr:hover {
                background-color: #f1f1f1;
            }

        .btn {
            font-size: 12px;
        }

        .product-image {
            max-width: 60px;
            max-height: 60px;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 5px;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
            justify-content: center;
        }

        .btn-create {
            background-color: #28a745;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 14px;
        }

            .btn-create:hover {
                background-color: #218838;
            }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Page Title -->
        <div class="page-title">
            Chi tiết sản phẩm
        </div>

        <!-- Add Product Button -->
  

        <!-- Product Table -->
        <div class="table-wrapper">
            <table class="table table-hover table-bordered text-center align-middle">
                <thead>
                    <tr>
                        <th>Mã sản phẩm</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá bán (VNĐ)</th>
                        <th>Trạng thái</th>
                        <th>Hàng còn</th>
                        <th>Kích cỡ</th>
                        <th>Loại sản phẩm</th>
                        <th>Thương hiệu</th>
                        <th>Ngày thêm sản phẩm</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaSp</td>
                            <td>
                                <img src="@Url.Content("/HinhAnh/" + item.HinhAnh)" alt="Product Image" class="product-image">
                            </td>
                            <td>@item.TenSp</td>
                            <td>@(item.GiaBan.HasValue ? ((decimal)item.GiaBan.Value).ToString("N0") : "N/A")đ</td>
                            <td>@item.TrangThai</td>
                            <td>@(item.HangTonKho ?? 0)</td>
                            <td>@item.KichCo</td>
                            <td>@item.MaLoaiNavigation.TenLoai</td>
                            <td>@item.MaLoaiNavigation.MaThNavigation.TenTh</td>
                            <td>@item.NgayThemSP?.ToString("dd/MM/yyyy")</td>

                            <td>
                                <div class="action-buttons">                              
                                    <form asp-action="xoaCtHangHoa" method="post" onsubmit="return confirmDelete(this);">
                                        <input type="hidden" name="xoaid" value="@item.MaSp" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </button>
                                    </form>
                               

                                    <form method="post" asp-action="formSuaSP">
                                        <input type="hidden" name="idsua" value="@item.MaSp" />
                                        <button type="submit" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit"></i> Sửa
                                        </button>
                                    </form>
                                </div>
                            </td>


                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <script>
        function confirmDelete(form) {
            const result = confirm("Bạn có chắc chắn muốn xóa sản phẩm này không?");
            return result; // Nếu người dùng nhấn "OK" (true) thì form sẽ được gửi, nếu nhấn "Cancel" (false) thì sẽ không gửi.
        }
    </script>
    <!-- Confirm Delete Script -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
