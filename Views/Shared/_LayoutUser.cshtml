* {
    font-family: 'Roboto Condensed', sans-serif;
    box-sizing: border-box;
}

body, html {
    font-size: 14px;
    color: #333;
    line-height: 1.5;
    margin: 0;
    width: 100%;
    min-height: 100%;
    background: #ffffff;
    overflow-x: hidden;
    scroll-behavior: smooth;
}

footer {
    background: #fff;
    padding: 40px 0;
}

.custom-container {
    margin: 0 auto;
    padding: 0 15px;
    max-width: 1140px;
}

.custom-row {
    display: flex;
    flex-wrap: wrap;
    margin: -12px;
}

.custom-col-lg-2, .custom-col-lg-4, .custom-col-sm-6, .custom-col-12 {
    padding: 12px;
    width: 100%;
}

.custom-col-lg-2 {
    flex: 0 0 16.666%;
}

.custom-col-lg-4 {
    flex: 0 0 33.333%;
}

.custom-footer-title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    position: relative;
}

.custom-ul {
    padding-left: 0;
    list-style: none;
}

.custom-ul li {
    margin-bottom: 12px;
}

.custom-ul li a {
    color: #288ad6;
    text-decoration: none;
    transition: color 0.3s ease;
}

.custom-ul li a:hover {
    color: #0056b3;
}

.custom-social-content {
    display: flex;
    flex-direction: column;
}

.custom-list-instagram {
    display: flex;
    gap: 10px;
    margin-top: 12px;
    padding: 0;
    list-style: none;
}

.custom-instagram-item a img {
    display: block;
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
}

#scroll-top {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    opacity: 0;
    visibility: hidden;
    z-index: -1;
    background: rgba(183, 211, 232, 0.2);
    border-radius: 50%;
    position: fixed;
    right: 23px;
    bottom: 17px;
    cursor: pointer;
    transition: all 0.5s ease;
}

#scroll-top svg {
    color: #333;
    font-size: 18px;
}

.custom-copyright {
    text-align: center;
    font-size: 12px;
    margin-top: 24px;
    color: #555;
}

		.image-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr); /* Chia 2 cột */
			gap: 10px; /* Khoảng cách giữa các hình */
			width: 100%; /* Đảm bảo khung vừa khung chứa */
			max-width: 600px; /* Điều chỉnh kích thước tối đa nếu cần */
			margin: 0 auto; /* Căn giữa lưới */
		}

			.image-grid img {
				width: 100%; /* Hình ảnh vừa khung cột */
				height: auto; /* Giữ nguyên tỉ lệ */
				border-radius: 5px; /* Thêm bo góc (tùy chọn) */
			}

    </style>
	@* Style Giayco nhan tao *@<style>
		/* Định dạng cơ bản cho menu */
		.menu-item {
			position: relative;
		}

		.submenu {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			background-color: #fff;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
			padding: 10px;
			border: 1px solid #ddd;
			border-radius: 5px;
			z-index: 1000;
			width: 250px; /* Đảm bảo đủ rộng */
		}

		/* Hiển thị submenu khi hover vào menu cha */
		.menu-item:hover .submenu {
			display: block;
		}

		/* Định dạng từng sản phẩm trong menu */
		.menu-product {
			position: relative;
			padding: 5px 0;
			border-bottom: 1px solid #eee;
		}

		/* Tên loại sản phẩm */
		.product-name {
			font-weight: bold;
			color: #000; /* Đen đậm */
			text-decoration: none; /* Bỏ gạch chân */
			display: inline-block;
			margin-right: 10px; /* Khoảng cách giữa loại sản phẩm và thương hiệu */
			font-size: 16px;
			transition: color 0.3s ease-in-out; /* Hiệu ứng chuyển màu */
		}

			/* Loại bỏ hiệu ứng hover cho tên loại sản phẩm */
			.product-name:hover {
				color: #000; /* Giữ màu đen khi hover */
			}

			/* Đảm bảo form không ảnh hưởng đến giao diện */
			.product-name form {
				display: inline-block; /* Đảm bảo form không chiếm toàn bộ chiều rộng */
				margin: 0; /* Loại bỏ khoảng cách mặc định */
			}

		/* Vùng chứa danh sách thương hiệu */
		.brand-names {
			display: none;
			position: absolute;
			top: 0;
			left: 100%; /* Hiển thị bên cạnh */
			padding: 5px;
			background-color: #fff;
			border: 1px solid #ddd;
			border-radius: 5px;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
			white-space: nowrap;
			z-index: 1000;
		}

		/* Hiển thị danh sách thương hiệu khi hover vào sản phẩm */
		.menu-product:hover .brand-names {
			display: block;
		}

		/* Định dạng từng thương hiệu */
		.brand-name {
			display: block; /* Mỗi thương hiệu hiển thị thành dòng riêng */
			font-size: 14px;
			color: #000; /* Đen đậm */
			margin: 5px 0;
			padding: 2px 5px;
			background-color: #f9f9f9;
			border-radius: 3px;
			border: 1px solid #eee;
			transition: background-color 0.3s ease-in-out; /* Thêm hiệu ứng cho brand-name */
		}

			/* Loại bỏ hiệu ứng hover cho thương hiệu */
			.brand-name:hover {
				background-color: #f9f9f9; /* Giữ màu nền khi hover */
				color: #000; /* Giữ màu chữ đen đậm khi hover */
			}

		/* Định dạng cho button trong form */
		button {
			background: none;
			border: none;
			font-size: 14px;
			color: #000; /* Đảm bảo màu chữ của button là đen */
			cursor: pointer;
			text-decoration: none; /* Bỏ gạch chân của button */
		}

			/* Loại bỏ hiệu ứng hover cho button */
			button:hover {
				color: #000; /* Giữ màu chữ đen khi hover */
				text-decoration: none; /* Bỏ gạch chân khi hover */
			}


	</style>
	<style>
		/* Định dạng form */
	

		/* Biểu tượng kính lúp */
		.ega-ic-search {
			width: 20px;
			height: 20px;
			fill: none;
			stroke: #000;
			stroke-width: 2;
		}

	</style>
	


	
</head>




@{
    var th = db.ThuongHieus.ToList();

    // 👇 LẤY DATA TRƯỚC (tránh lỗi EF)
    var loaiSanPhams = db.LoaiSanPhams
        .Include(x => x.MaThNavigation)
        .ToList();

    // 👇 GROUP TRONG RAM (KHÔNG phải SQL)
    var groupedData = loaiSanPhams
        .GroupBy(lsp => lsp.TenLoai)
        .Select(g => new
        {
            TenLoai = g.Key,
            ThuongHieus = g
                .Where(x => x.MaThNavigation != null)
                .Select(x => x.MaThNavigation.TenTh)
                .Distinct()
                .ToList()
        })
        .ToList();

}






   
