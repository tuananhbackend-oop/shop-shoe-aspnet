@model List<LVTNWEBGIAYDEP.Models.LienHe>
@{
    ViewData["Title"] = "formNhanTin";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}


<style>

    /* Đảm bảo trang chiếm toàn bộ chiều cao màn hình */
    html, body {
        height: 100%;
        margin: 0;
        font-family: Arial, sans-serif;
        background-color: #121212; /* Màu nền tối */
        color: white;
    }

    /* Khung bao quanh toàn bộ nội dung */
    .container-chat {
        background-color: #2f2f2f;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        width: 90%;
        max-width: 1000px;
        margin: 20px auto;
        display: flex;
        flex-direction: column;
    }

    h1 {
        text-align: center;
        font-size: 24px;
        color: #00b4d8;
        margin-bottom: 20px;
    }


    /* Cải thiện khung chat hiển thị lịch sử phản hồi */
    .chat-container {
        background-color: #1c1c1c; /* Màu nền xám đen cho toàn bộ khung chat */
        padding: 20px;
        border-radius: 10px;
        flex-grow: 1; /* Chiếm hết không gian còn lại */
        overflow-y: scroll;
        margin-bottom: 0; /* Khoảng cách dưới cùng */
        margin-top:50px;
        max-height: 60vh; /* Giới hạn chiều cao chat container */
        box-sizing: border-box; /* Đảm bảo padding không làm thay đổi chiều cao */
      
    }

    .col-md-12 {
        background-color: #1c1c1c; /* Màu nền xám đen cho toàn bộ khung chat */
        padding: 20px;
        border-radius: 10px;
        flex-grow: 1; /* Chiếm hết không gian còn lại */
        overflow-y: auto; /* Cho phép cuộn khi nội dung vượt quá giới hạn */
        margin-bottom: 20px; /* Khoảng cách dưới cùng */
        box-sizing: border-box; /* Đảm bảo padding không làm thay đổi chiều cao */
    }
    /* Lịch sử phản hồi */
    .user-message, .admin-reply {
        padding-top:30px;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 8px;
        max-width: 300px; /* Đặt chiều rộng tối đa là 300px */
        word-wrap: break-word;
        white-space: normal;
        display: inline-block; /* Màu nền chỉ bao quanh nội dung */
    }

    /* Màu nền cho nội dung người dùng */
    .user-message {
        background-color: #333333; /* Xám đậm cho nội dung người dùng */
        color: white;
        margin-left: 0;
        margin-right: auto;
    }

    /* Màu nền cho phản hồi admin */
    .admin-reply {
        background-color: #007bff; /* Xanh dương cho phản hồi admin */
        color: white;
        margin-left: auto;
        margin-right: 0;
    }

    /* Đảm bảo các đoạn văn không vượt quá chiều rộng tối đa */
    .reply-content, .user-message {
        word-break: break-word; /* Tự động xuống dòng khi gặp từ dài */
        max-width: 100%; /* Đảm bảo không bị tràn khung */
    }

    /* Để đảm bảo khung cuộn mượt mà */
    .user-message {
        background-color: #333333; /* Màu nền xám đậm */
        color: white;
        padding: 12px;
        border-radius: 10px;
        max-width: 300px; /* Giới hạn chiều rộng tối đa */
        word-wrap: break-word; /* Xuống dòng khi vượt quá chiều rộng */
        white-space: normal;
        margin-left: 0; /* Căn sát bên trái */
        margin-right: auto; /* Đẩy lề bên phải ra xa */
    }

    /* Nội dung phản hồi của admin */
    .admin-reply {
        background-color: #007bff; /* Màu nền xanh dương */
        color: white;
        padding: 8px;
        border-radius: 10px;
        max-width: 300px; /* Giới hạn chiều rộng tối đa */
        word-wrap: break-word; /* Xuống dòng khi vượt quá chiều rộng */
        white-space: normal;
        margin-left: auto; /* Đẩy lề bên trái ra xa */
        margin-right: 0; /* Căn sát bên phải */
    }

    /* Khoảng cách giữa các đoạn chat */
    .chat-container {
        display: flex;
        flex-direction: column; /* Hiển thị các đoạn chat theo chiều dọc */
        gap: 9px; /* Khoảng cách giữa các đoạn chat */
    }

        .chat-container::-webkit-scrollbar {
            width: 8px;
        }

        .chat-container::-webkit-scrollbar-thumb {
            background-color: #444; /* Màu cho thanh cuộn */
            border-radius: 4px;
        }
    /* Form nhập phản hồi */
    .form-group textarea {
        border-radius: 8px;
        padding: 12px;
        background-color: #333333; /* Nền tối cho textarea */
        color: white;
        border: 1px solid #444444;
        width: 100%;
        height: 50px; /* Chiều cao textarea */
        resize: none; /* Không cho phép thay đổi kích thước */
        margin-bottom: 12px;
    }

    /* Nút gửi phản hồi */
    .btn-primary {
        background-color: #28a745; /* Xanh lá */
        border-color: #28a745;
        padding: 10px 20px;
        font-size: 18px;
        border-radius: 8px;
        transition: background-color 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-primary i {
            font-size: 20px;
            margin-right: 8px;
        }

        .btn-primary:hover {
            background-color: #218838; /* Màu xanh lá đậm khi hover */
        }

    .d-flex {
        display: flex;
        align-items: center;
    }

    .ml-2 {
        margin-left: 10px; /* Khoảng cách giữa textarea và nút */
    }

    /* Link quay lại */
    .back-link {
        display: inline-block;
        margin-top: 20px;
        color: #007bff;
        text-decoration: none;
        font-size: 16px;
    }

        .back-link:hover {
            text-decoration: underline;
        }


</style>
<div class="container-chat">
    <h1 style="color: #007bff; position: relative;">
        Đang kết nối với nhân viên chăm sóc khách hàng
        <form asp-action="xoaLienHeUser" method="post">
            <input type="hidden" value="@Model.FirstOrDefault()?.TaiKhoan" name="taiKhoan" />
            <button type="submit" style="position: absolute; right: 0; top: 0; cursor: pointer; color: red; border: none; background: transparent;">
                &#10006;
            </button>
        </form>

       
    </h1>

    <div class="row">
        <div class="col-md-12">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Khung chat hiển thị lịch sử phản hồi -->
            <div class="form-group">
                <div class="chat-container">
                    @foreach (var lienHe in Model)
                    {
                        @if (!string.IsNullOrEmpty(lienHe.noiDungPhanHoi))
                        {
                            <!-- Tin nhắn người dùng -->
                            <div class="user-message">@lienHe.noiDungPhanHoi</div> <!-- User's message -->
                        }
                        @if (string.IsNullOrEmpty(lienHe.noiDungPhanHoi))
                        {
                            <div class="admin-reply">
                                <!-- Nội dung phản hồi, ẩn khi sửa -->
                                <span class="reply-content" id="reply-content-@lienHe.Id" style="display: block;">@lienHe.NoiDung</span>

                                <!-- Icon ba chấm ngay sau nội dung -->
                                <div class="dropdown d-inline">
                                    <button class="btn btn-link dropdown-toggle text-white p-0" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
                                        <li>
                                            <!-- Nút sửa với ID duy nhất -->
                                            <button class="dropdown-item text-danger" type="button" onclick="showEditForm(@lienHe.Id)">Sửa</button>
                                        </li>
                                        <li>
                                            <form method="post" asp-action="xoaNoiDung">
                                                <input type="hidden" name="phoi" value="@lienHe.Id" />
                                                <input type="hidden" name="tkhoan" value="@lienHe.TaiKhoan" />
                                                <button class="dropdown-item text-danger" type="submit">Xóa</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>

                                <!-- Form sửa phản hồi, ẩn mặc định -->
                                <div id="editForm-@lienHe.Id" style="display: none;">
                                    <form method="post" asp-action="suaNoiDung">
                                        <input type="hidden" name="Id" value="@lienHe.Id" />
                                        <input type="hidden" name="tkhoan" value="@lienHe.TaiKhoan" />
                                        <!-- Hiển thị nội dung cũ trong form nhập -->
                                        <textarea name="ndphnew" placeholder="Nhập nội dung sửa..." required>@lienHe.NoiDung</textarea>
                                        <button class="btn btn-primary" type="submit">Cập nhật</button>
                                        <!-- Nút đóng -->
                                        <button type="button" class="btn btn-secondary" onclick="closeEditForm(@lienHe.Id)">Đóng</button>
                                    </form>
                                </div>
                            </div>


                        }
                    }
                </div>

            </div>

            <style>

                .admin-reply {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    padding: 12px;
                    border-radius: 10px;
                    background-color: #007bff; /* Màu xanh dương */
                    color: white;
                    margin-bottom: 12px;
                    position: relative; /* Để quản lý vị trí của các phần tử con */
                }

                .reply-content {
                    flex: 1; /* Chiếm toàn bộ không gian còn lại */
                    word-wrap: break-word;
                    white-space: normal;
                }

                .dropdown {
                    margin-left: 8px;
                }

                .dropdown-toggle {
                    color: white;
                    font-size: 18px;
                    border: none;
                    background: none;
                    padding: 0;
                }

                    .dropdown-toggle:hover {
                        color: #eaeaea;
                    }

                .dropdown-menu {
                    min-width: 120px;
                }
                /* Form nhập phản hồi */
                textarea#noiDungPhanHoi {
                    border-radius: 8px;
                    padding: 12px;
                    background-color: #333333; /* Nền tối cho textarea */
                    color: white;
                    border: 2px solid white; /* Viền trắng tinh */
                    width: 100%;
                    height: 50px; /* Chiều cao textarea */
                    resize: none; /* Không cho phép thay đổi kích thước */
                    margin-bottom: 12px;
                    outline: none; /* Xóa viền mặc định khi chọn */
                }

                    /* Hiệu ứng khi người dùng tập trung vào ô nhập */
                    textarea#noiDungPhanHoi:focus {
                        border-color: #ffcc00; /* Đổi viền sang màu vàng sáng khi focus */
                        box-shadow: 0 0 8px #ffcc00; /* Hiệu ứng ánh sáng vàng xung quanh */
                        transition: border-color 0.3s ease, box-shadow 0.3s ease; /* Hiệu ứng mượt */
                    }

                    textarea#noiDungPhanHoi::placeholder {
                        color: white; /* Màu trắng cho placeholder */
                        opacity: 0.8; /* Độ trong suốt để làm nổi bật */
                    }

                    /* Tăng độ tương phản khi focus vào textarea */
                    textarea#noiDungPhanHoi:focus::placeholder {
                        opacity: 1; /* Đặt độ trong suốt về 1 khi focus */
                        transition: opacity 0.3s ease; /* Hiệu ứng chuyển đổi mượt */
                    }

            </style>
         
            <!-- Form phản hồi admin -->
         

        </div>
        <form asp-action="ThemNoiDung" method="post">
            <div class="form-group d-flex align-items-center">
                <textarea id="noiDungPhanHoi" name="noiDungPhanHoi" class="form-control" placeholder="Nhập nội dung..." required></textarea>
                <button type="submit" class="btn btn-primary ml-2">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
            <input type="hidden" name="taiKhoan" value="@Model.FirstOrDefault()?.TaiKhoan" />
        </form>
    </div>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

  
    <script>
        function showEditForm(id) {
            // Ẩn các form sửa khác
            const allEditForms = document.querySelectorAll("[id^='editForm-']");
            allEditForms.forEach(function (form) {
                form.style.display = "none";  // Ẩn các trường nhập khác
            });

            // Ẩn nội dung cũ khi hiển thị form sửa
            const replyContent = document.getElementById("reply-content-" + id);
            if (replyContent) {
                replyContent.style.display = "none";  // Ẩn nội dung phản hồi cũ
            }

            // Hiển thị form sửa cho id hiện tại
            const editForm = document.getElementById("editForm-" + id);
            if (editForm) {
                editForm.style.display = "block";  // Hiển thị form sửa
            } else {
                console.log("Không tìm thấy form với id editForm-" + id);
            }
        }

        function closeEditForm(id) {
            // Ẩn form sửa và hiển thị lại nội dung phản hồi
            const editForm = document.getElementById("editForm-" + id);
            if (editForm) {
                editForm.style.display = "none";  // Ẩn form sửa
            }

            const replyContent = document.getElementById("reply-content-" + id);
            if (replyContent) {
                replyContent.style.display = "block";  // Hiển thị lại nội dung phản hồi cũ
            }
        }


    </script>


    <div>
        <a href="@Url.Action("Index","LienHe")" class="back-link">Về liên hệ</a>
    </div>
</div>

