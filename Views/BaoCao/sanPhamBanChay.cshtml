@using Microsoft.EntityFrameworkCore
@using LVTNWEBGIAYDEP.Models
@inject DBGiayDepContext db
@{
    ViewData["Title"] = "sanPhamBanChay";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@{
   

    // Lấy danh sách đơn hàng hoàn tất
    var donHangHoanTat = db.DonHangs
        .Where(dh => dh.trangThai == "Hoàn Tất")
        .ToList();

    // Tạo dictionary để lưu số lượng mua của từng sản phẩm
    var sanPhamBanChay = new Dictionary<string, int>();

    foreach (var dhht in donHangHoanTat)
    {

        // Lấy danh sách chi tiết đơn hàng của đơn hàng hiện tại
        var chiTietDonHang = db.ChiTietDonHangs
            .Where(ctdh => ctdh.iDDonHang == dhht.iDDonHang)
            .ToList();

        foreach (var ctdhht in chiTietDonHang)
        {
            // Lấy ID sản phẩm
            string maSanPham = ctdhht.MaSp;

            // Lấy số lượng mua
            int soLuong = ctdhht.SoLuong ?? 0;

            // Cộng dồn số lượng vào dictionary
            if (sanPhamBanChay.ContainsKey(maSanPham))
            {
                sanPhamBanChay[maSanPham] += soLuong;
            }
            else
            {
                sanPhamBanChay[maSanPham] = soLuong;
            }
        }
    }

    // Sắp xếp danh sách sản phẩm theo số lượng mua giảm dần
    var sanPhamBanChaySapXep = sanPhamBanChay
     .OrderByDescending(sp => sp.Value)
     .Take(10) // Lấy 10 sản phẩm
     .ToList();

    // Lấy thông tin chi tiết sản phẩm từ database
    var sanPhamChiTiet = sanPhamBanChaySapXep
        .Select(sp => new
        {
            SanPham = db.SanPhams.Find(sp.Key),
            SoLuong = sp.Value
        })
        .ToList();
}
@foreach (var sp in sanPhamChiTiet)
{
    sp.SanPham.MaLoaiNavigation = db.LoaiSanPhams.Find(sp.SanPham.MaLoai);
    List<LoaiSanPham> loaiSanPhams = db.LoaiSanPhams.ToList();
    foreach(var it in loaiSanPhams)
    {
        it.MaThNavigation = db.ThuongHieus.Find(it.MaTh);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý sản phẩm</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome (Icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
            font-size: 14px;
        }

        .page-title {
            background-color: #007bff;
            color: white;
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            margin-bottom: 20px;
         

        
            font-size: 24px; /* Điều chỉnh kích thước theo ý muốn */
            font-weight: bold; /* Thêm đậm nếu cần */
        
        }

        .table-wrapper {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .table {
            font-size: 14px;
            margin-bottom: 0;
        }

        .table thead {
            background-color: #343a40;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f1f1f1;
        }

        .btn {
            font-size: 12px;
        }

        .product-image {
            max-width: 60px;
            max-height: 60px;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 5px;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
            justify-content: center;
        }

        .btn-create {
            background-color: #28a745;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 14px;
        }

        .btn-create:hover {
            background-color: #218838;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Page Title -->
        <div class="page-title">
            Danh sách sản phẩm bán chạy
        </div>
        <!-- Product Table -->
        <div class="table-wrapper">
            <table class="table table-hover table-bordered text-center align-middle">
                <thead>
                    <tr>
                        <th>Mã sản phẩm</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá bán (VNĐ)</th>
                        <th>Số lượng mua</th>                        
                        <th>Loại sản phẩm</th>
                        <th>Thương hiệu</th>
                                 
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sp in sanPhamChiTiet)
                    {
                        
                        <tr>
                            <td>@sp.SanPham.MaSp</td>
                            <td>
                                <img src="@Url.Content("/HinhAnh/" + sp.SanPham.HinhAnh)" alt="Product Image" class="product-image">
                            </td>
                            <td>@sp.SanPham.TenSp</td>
                            <td>@(sp.SanPham.GiaBan.HasValue ? ((decimal)sp.SanPham.GiaBan.Value).ToString("N0") : "N/A")đ</td>                                                
                            <td>@sp.SoLuong</td>
                            <td>@sp.SanPham.MaLoaiNavigation.TenLoai</td>
                            <td>@sp.SanPham.MaLoaiNavigation.MaThNavigation.TenTh</td>

                           
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Confirm Delete Script -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>


