@using LVTNWEBGIAYDEP.Models
@using Microsoft.EntityFrameworkCore
@inject DBGiayDepContext db
@{
    ViewData["Title"] = "baoCao";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@{
  
    var ltaikhoan = db.TaiKhoans.ToList();
    var ldonHang = db.DonHangs.ToList();
    var soTaiKhoanHoatDong = ltaikhoan.Count(tk => tk.trangThai == "Hoạt Động");
    var soTaiKhoanDongBang = ltaikhoan.Count(tk => tk.trangThai == "Đóng Băng");
    var donHangDangDat = ldonHang.Count(dh => dh.trangThai == "Chờ xác nhận");
    var donHangDangDat1 = ldonHang.Count(dh => dh.trangThai == "Chờ lấy hàng");
    var donHangDangDat2 = ldonHang.Count(dh => dh.trangThai == "Chờ giao hàng");
    var donHangDangDat3 = ldonHang.Count(dh => dh.trangThai == "Đã nhận được hàng");
    var tongdonhang = donHangDangDat + donHangDangDat1 + donHangDangDat2+donHangDangDat3;
    var donHangDaHuy = ldonHang.Count(dh => dh.trangThai == "Đã Huỷ");
    var donHangHoanTat = ldonHang.Count(dh => dh.trangThai == "Hoàn Tất"); 
    var donHangKhongNhan = ldonHang.Count(dh => dh.trangThai == "Không Nhận");
    decimal tongtien = 0;
    @foreach (DonHang dhht in ldonHang)
    {
        if (dhht.trangThai == "Hoàn Tất")
        {
            dhht.ChiTietDonHangs = db.ChiTietDonHangs.Where(t => t.iDDonHang == dhht.iDDonHang).ToList();

            foreach (ChiTietDonHang ctdhht in dhht.ChiTietDonHangs)
            {
                ctdhht.MaSpNavigation = db.SanPhams.Find(ctdhht.MaSp);
                decimal giaBan = ctdhht.MaSpNavigation.GiaBan ?? 0m; // Null-coalescing for GiaBan
                int soLuong = ctdhht.SoLuong ?? 0; // Null-coalescing for SoLuong
                tongtien += giaBan * soLuong; // Perform multiplication
            }
        }
    }

}

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f4f4f4;
    }

    header {
        background-color: #333;
        color: white;
        padding: 15px;
        text-align: center;
    }

    nav ul {
        list-style: none;
        padding: 0;
    }

        nav ul li {
            display: inline;
            margin: 0 15px;
        }

            nav ul li a {
                color: white;
                text-decoration: none;
            }

    main {
        padding: 20px;
    }

    .statistics {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .stat-box {
        background-color: white;
        border: 1px solid #ddd;
        padding: 20px;
        text-align: center;
    }

    h2 {
        font-size: 1.2em;
        margin-bottom: 10px;
    }

    p {
        font-size: 1.5em;
        font-weight: bold;
    }

  

</style>
<style>
    .dropdown {
        position: relative; /* Đặt vị trí của phần tử cha là tương đối */
    }

    .dropdown-menu {
        position: absolute; /* Menu con được định vị tuyệt đối */
        top: 100%; /* Canh phía dưới phần tử cha */
        left: 0; /* Canh trái */
        background-color: white;
        border: 1px solid #ccc;
        border-radius: 5px; /* Thêm bo góc */
        padding: 0;
        margin: 0;
        list-style: none;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); /* Đổ bóng */
        display: none; /* Mặc định ẩn menu */
        z-index: 1000;
        min-width: 150px; /* Đặt chiều rộng tối thiểu */
    }

        .dropdown-menu li {
            padding: 10px 15px;
            cursor: pointer;
            transition: background-color 0.3s; /* Hiệu ứng khi hover */
        }

            .dropdown-menu li a {
                text-decoration: none;
                color: #333;
                display: block;
            }

        


</style>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Báo Cáo Admin</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <header>
        <h1> Admin</h1>
        <nav>
            <ul>
                <li><a asp-action="bieuDo">Biểu đồ 7 ngày</a></li>
              
                <li><a asp-action="bieuDonam">Biểu đồ 1 năm</a></li>
                <li><a asp-action="sanPhamBanChay">Sản phẩm bán chạy</a></li>
               

               
            </ul>
        </nav>
    </header>

    <main>
        <section class="statistics">
            <div class="stat-box">
                <h2>Số tài khoản hoạt động</h2>
                <p id="frozen-accounts">@soTaiKhoanHoatDong</p>
               
            </div>
            <div class="stat-box">
                <h2>Số tài khoản đóng băng</h2>
                <p id="frozen-accounts">@soTaiKhoanDongBang</p>
            </div>
            <div class="stat-box">
                <h2>Đơn hàng đang đặt</h2>
                <p id="pending-orders">@tongdonhang</p>
            </div>
            <div class="stat-box">
                <h2>Đơn hàng đã huỷ</h2>
                <p id="cancelled-orders">@donHangDaHuy</p>
            </div>
            <div class="stat-box">
                <h2>Đơn hàng hoàn thành</h2>
                <p id="completed-orders">@donHangHoanTat</p>
            </div>
            <div class="stat-box">
                <h2>Đơn hàng không nhận</h2>
                <p id="not-received-orders">@donHangKhongNhan</p>
            </div>
            <div class="stat-box">
                <h2>Tổng doanh thu </h2>
                <p id="monthly-revenue">  @(tongtien == 0 ? "N/A" : tongtien.ToString("N0")) đ</p>
          
            </div>
        </section>

      
    </main>
    <script>
        const dropdown = document.getElementById("monthDropdown");
        const parent = dropdown.parentElement;

        parent.addEventListener("mouseenter", () => {
            dropdown.style.display = "block";
        });

        parent.addEventListener("mouseleave", () => {
            dropdown.style.display = "none";
        });

    </script>
</body>
</html>


