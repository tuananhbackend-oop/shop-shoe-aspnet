@using LVTNWEBGIAYDEP.Models
@using Microsoft.EntityFrameworkCore
@inject DBGiayDepContext db

@{
    ViewData["Title"] = "loaiSanPham";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@{
    var ds = db.LoaiSanPhams
        .Include(x => x.MaThNavigation)
        .ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh Sách Loại Sản Phẩm</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome (Icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
        }
        .header-title {
            background-color: #28a745;
            color: white;
            padding: 15px 0;
            border-radius: 10px;
            text-align: center;
            font-weight: bold;
        }
        .btn-custom {
            padding: 8px 20px;
            border-radius: 25px;
        }
        .table-container {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .table thead {
            background-color: #343a40;
            color: white;
        }
        .table tbody tr:hover {
            background-color: #f1f1f1;
        }
    </style>
    <style>
        .message-box {
            margin: 20px auto; /* Tạo khoảng cách và căn giữa theo chiều ngang */
            padding: 15px;
            border-radius: 8px;
            font-size: 16px;
            text-align: center;
            max-width: 600px;
            width: auto;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        }

            .message-box.success {
                background-color: #d4edda;
                color: #155724;
                border: 1px solid #c3e6cb;
            }

            .message-box.error {
                background-color: #f8d7da;
                color: #721c24;
                border: 1px solid #f5c6cb;
            }

    </style>
</head>
<body>
    @if (ViewBag.SuccessMessage != null)
    {
        <div class="message-box success">
            @ViewBag.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="message-box error">
            @ViewBag.ErrorMessage
        </div>
    }
    <!-- Header -->
    <div class="container my-4">
        <div class="header-title">
            <h1>Danh sách loại sản phẩm</h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4">Quản lý loại sản phẩm</h2>
            <a asp-action="formThemLoaiSanPham" class="btn btn-success btn-custom">
                <i class="fas fa-plus"></i> Thêm loại sản phẩm
            </a>
        </div>

        <!-- Table -->
        <div class="table-container">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead>
                        <tr>
                        
                            <th>Tên loại</th>
                            <th>Tên thương hiệu</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>

                       
               
                        @foreach (var item in ds)
                        {
                             
                          
                         
                            <tr>
                               
                                <td>@item.TenLoai</td>
                                <td>@item.MaThNavigation.TenTh</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <!-- Edit Button -->
                                        <form method="post" asp-action="formSuaLoaiSP" class="m-0">
                                            <input type="hidden" name="idsua" value="@item.MaLoai" />
                                            <button type="submit" class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Sửa 
                                            </button>
                                        </form>

                                        <!-- Delete Button -->
                                        <form id="formXoaLoaiSP" asp-action="xoaLoaiSP" method="post" class="m-0" style="display:none;">
                                            <input type="hidden" id="xoasp" name="xoasp" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash-alt"></i> Xóa
                                            </button>
                                        </form>

                                        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete('@item.MaLoai')">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


  

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
   
    <script>
        function confirmDelete(maLoai) {
            if (window.confirm(`Bạn có thực sự muốn xoá loại sản phẩm "${maLoai}" này không?`) ){
                // Nếu người dùng chọn "Ok", gán giá trị vào input và submit form
                document.getElementById("xoasp").value = maLoai;
                document.getElementById("formXoaLoaiSP").submit();
            }
        }
    </script>
</body>
</html>
