		}

		.summary-item {
			display: flex;
			justify-content: flex-start ;
			font-size: 16px;
			padding: 8px;
			width: 100% ;
			background-color: #fff;
			border: 1px solid #ddd;
			border-radius: 8px;
		}

			.summary-item .label {
				font-weight: bold;

				color: #333;
			}

			.summary-item .value {
				text-align: left;
				display: block; /* Đảm bảo phần tử span sẽ hiển thị theo kiểu block để dễ dàng canh lề */

			}

		/* Đảm bảo toàn bộ order-summary sẽ căn lề trái */
