<body class="template_cart" id="ega-fashion">



	<div class="ega-cart" id="ega-cart">
		<div class="ega-container">

			<div class="ega-cart__wrap">
				<div class="ega-cart-content">
					<div class="order-summary">
						<div class="summary-item">
							<span class="label" style="margin-right: 12px">Số điện thoại:</span>
							<span class="value">@Model.SoDienThoai</span>
						</div>
						<div class="summary-item">
							<span class="label" style="margin-right: 50px">Địa chỉ:</span>
							<span class="value">@Model.DiaChi</span>
						</div>
						<div class="summary-item">
							<span class="label" style="margin-right: 14px">Thanh toán:</span>
							<span class="value">@Model.thanhToan</span>
						</div>
					</div>

					<div class="cart-body-left">
						<div class="ega-cart-head">
							<div class="ega-row">
								<div class="ega-col-md-1"></div>
								<div class="ega-col-md-11">
									<div class="ega-row">
										<div class="ega-col-5">Sản phẩm</div>
										<div class="ega-col-2">Đơn giá</div>
										<div class="ega-col-3">Số lượng</div>
										<div class="ega-col-2">Thành tiền</div>
									</div>
								</div>
							</div>
						</div>
						@{
							int tongTien = 0;
						}
						@foreach (var item in Model.ChiTietDonHangs)
						{
							<div class="ega-cart-body">
								<div class="ega-row ega-cart-row">
									<div class="ega-col-md-1 ega-col-2 ega-text--right">
									</div>

									<div class="ega-col-md-11 ega-col-10">
										<div class="ega-row ega-cart-info">
											<div class="ega-col-md-2 ega-col-12 ega-cart-img">
												<a class="ega-d--block" href="/products/joma-top-flex-pito-tf-2462-trang-hong">
													<img width="150" src="@Url.Content("/HinhAnh/"+item.MaSpNavigation.HinhAnh)" />
												</a>
											</div>
											<div class="ega-col-md-3 ega-col-12">
												<a class="ega-link ega-color--initial" href="/products/joma-top-flex-pito-tf-2462-trang-hong"><h5 class="cart-pd-title">@item.MaSpNavigation.TenSp</h5></a>
												<div class="cart-variant">
													<span>@item.MaSpNavigation.KichCo</span>
												</div>
											</div>
											<div class="ega-col-md-2 ega-col-12"><span class="cart-item-price">@item.MaSpNavigation.GiaBan</span></div>
											<div class="ega-col-md-3 ega-col-12">
												<div class="ega-d--flex ega-cart-quantity" data-ega-role="qty-wrapper">
													@item.SoLuong
												</div>
											</div>
											<div class="ega-col-md-2 ega-col-12"><span class="line-item-total"> @(item.SoLuong * item.MaSpNavigation.GiaBan)</span></div>
										</div>
									</div>
								</div>
							</div>
							tongTien += (int)(item.SoLuong * item.MaSpNavigation.GiaBan.Value);
						}
					</div>
					<div class="ega-cart-total">
						<div class="ega-cart-total__content">
							<span class="total-label">Tổng thanh toán:</span>
							<span class="total-amount">@tongTien.ToString("N0")đ</span>
						</div>
					</div>
				</div>

			</div>

		</div>
	</div>

</body>
</html>


