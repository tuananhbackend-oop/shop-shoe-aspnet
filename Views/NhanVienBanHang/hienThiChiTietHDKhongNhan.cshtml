			font-family: Arial, sans-serif;
		}

		.ega-cart-total__content {
			display: inline-flex; /* Hiển thị nội dung theo chiều ngang */
			justify-content: flex-end; /* Đẩy nội dung sang phải */
			align-items: center; /* Căn giữa dọc */
			gap: 10px; /* Khoảng cách giữa nhãn và số tiền */
		}

		.total-label {
			font-size: 18px;
			font-weight: bold;
			color: #333;
		}

