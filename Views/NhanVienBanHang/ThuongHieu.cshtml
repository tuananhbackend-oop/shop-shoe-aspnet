@model IEnumerable<LVTNWEBGIAYDEP.Models.ThuongHieu>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutNVBH.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Thương Hiệu</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome (Icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
        }
        .header-title {
            background-color: #007bff;
            color: white;
            padding: 15px 0;
            border-radius: 10px;
            text-align: center;
            font-weight: bold;
        }
        .btn-custom {
            padding: 8px 20px;
            border-radius: 25px;
        }
        .table-container {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .table thead {
            background-color: #343a40;
            color: white;
        }
        .table tbody tr:hover {
            background-color: #f1f1f1;
        }
    </style>
    <style>
        .message-box {
            margin: 20px auto; /* Tạo khoảng cách và căn giữa theo chiều ngang */
            padding: 15px;
            border-radius: 8px;
            font-size: 16px;
            text-align: center;
            max-width: 600px;
            width: auto;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        }

            .message-box.success {
                background-color: #d4edda;
                color: #155724;
                border: 1px solid #c3e6cb;
            }

            .message-box.error {
                background-color: #f8d7da;
                color: #721c24;
                border: 1px solid #f5c6cb;
            }

    </style>
</head>
<body>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="message-box success">
            @ViewBag.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="message-box error">
            @ViewBag.ErrorMessage
        </div>
    }
    <!-- Header -->
    <div class="container my-4">
        <div class="header-title">
            <h1>Quản Lý Thương Hiệu</h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4">Danh Sách Thương Hiệu</h2>
          
        </div>

        <!-- Table -->
        <div class="table-container">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead>
                        <tr>
                            <th class="text-center">Mã Thương Hiệu</th>
                            <th>Tên Thương Hiệu</th>
                       
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">@item.MaTh</td>
                                <td>@item.TenTh</td>
                              
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p class="mb-0">© 2024 Quản Lý Thương Hiệu. Designed with ❤️ by Your Company</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
 
</body>
</html>


