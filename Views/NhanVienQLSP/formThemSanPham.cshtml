@model LVTNWEBGIAYDEP.Models.SanPham

@{
    ViewData["Title"] = "Form Thêm Sản Phẩm";
    Layout = "~/Views/Shared/_LayoutNVQLSP.cshtml";
}

<style>
    /* Giảm chiều rộng của các input và select */
    .form-control-sm {
        font-size: 0.875rem;
        padding: 0.75rem;
        max-width: 100%; /* Đảm bảo các input và select chiếm hết chiều rộng */
        width: 100%; /* Chiều rộng đầy đủ của cột */
        box-sizing: border-box;
    }

    /* Căn giữa các input */
    .form-group {
        margin-bottom: 15px;
        display: block; /* Sắp xếp theo chiều dọc */
        text-align: left; /* Căn trái label */
    }

    /* Cải thiện nút submit */
    .btn-sm {
        font-size: 1rem;
        padding: 1rem;
    }

    /* Hiệu ứng hover cho nút */
    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #0056b3;
            border-color: #004085;
            transform: scale(1.05);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .btn-primary:focus {
            outline: none;
            box-shadow: 0 0 5px rgba(0, 123, 255, 0.6);
        }

    /* Tăng chiều rộng form */
    .form-container {
        max-width: 600px;
        margin: 0 auto;
    }

    /* Căn chỉnh label và input cho đẹp */
    .form-group label {
        display: block; /* Đảm bảo label chiếm một dòng riêng */
        margin-bottom: 5px; /* Khoảng cách giữa label và input */
        font-weight: bold;
        color: #007bff;
    }
</style>

<h4 class="text-center" style="font-size: 1.5rem; color: #007bff; text-align: center;">Thêm Sản Phẩm</h4>
<hr />

<!-- Form Thêm Sản Phẩm -->
<div class="row justify-content-center">
    <div class="col-md-6 form-container">
        <div class="card shadow-lg border-light">
            <div class="card-header bg-info text-white text-center">
            </div>
            <div class="card-body">
                <form asp-action="themSanPham" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Mã Sản Phẩm -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Mã Sản Phẩm</label>
                        <input asp-for="MaSp" class="form-control form-control-sm" placeholder="Nhập Mã Sản Phẩm" />
                    </div>

                    <!-- Tên Sản Phẩm -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Tên Sản Phẩm</label>
                        <input asp-for="TenSp" class="form-control form-control-sm" placeholder="Nhập Tên Sản Phẩm" />
                    </div>

                    <!-- Hình Ảnh -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Hình Ảnh</label>
                        <input type="file" name="fileImg" class="form-control form-control-sm" />
                    </div>

                    <!-- Giá Bán -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Giá Bán</label>
                        <input asp-for="GiaBan" class="form-control form-control-sm" placeholder="Nhập Giá Bán" />
                    </div>

                    <!-- Trạng Thái -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Trạng Thái</label>
                        <input asp-for="TrangThai" class="form-control form-control-sm" />
                    </div>

                    <!-- Mô Tả -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Mô Tả</label>
                        <input asp-for="MoTa" class="form-control form-control-sm" />
                    </div>

                    <!-- Hàng Tồn Kho -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Hàng Tồn Kho</label>
                        <input asp-for="HangTonKho" class="form-control form-control-sm" />
                    </div>

                    <!-- Kích Cỡ -->
                    <div class="form-group">
                        <label class="control-label text-primary" style="font-size: 0.875rem;">Kích Cỡ</label>
                        <input asp-for="KichCo" class="form-control form-control-sm" />
                    </div>

                    <!-- Tên Loại Sản Phẩm -->
                    <select asp-for="MaLoai" id="loaiSanPhamDropdown" class="form-control form-control-sm">
                        <option value="">Chọn loại sản phẩm</option>
                        @foreach (var group in (dynamic)ViewBag.GroupedLoaiSanPham)
                        {
                            <optgroup label="@group.TenLoai">
                                @foreach (var item in group.MaLoaiList)
                                {
                                    <option value="@item.MaLoai">
                                        @group.TenLoai - Thương hiệu: @item.TenTh
                                    </option>
                                }
                            </optgroup>
                        }
                    </select>

                

                    <!-- Nút Submit -->
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary btn-sm btn-block shadow-sm" style="font-size: 1rem; padding: 1rem;">
                            <i class="fas fa-save"></i> Thêm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Nút quay lại -->
<div class="mt-3 text-center">
    <a asp-action="SanPham" class="btn btn-outline-info btn-sm">
        <i class="fas fa-arrow-left"></i> Trở Về
    </a>
</div>


<!-- Include Font Awesome for Icons -->
<script src="https://kit.fontawesome.com/a076d05399.js"></script>
