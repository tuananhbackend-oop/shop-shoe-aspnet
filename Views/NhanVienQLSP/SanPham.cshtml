@model IEnumerable<LVTNWEBGIAYDEP.Models.SanPham>

@{
    ViewData["Title"] = "SanPham";
    Layout = "~/Views/Shared/_LayoutNVQLSP.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh Sách Sản Phẩm</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome (Icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
            font-size: 14px; /* Giảm kích thước font chữ toàn trang */
        }

        .page-title {
            background-color: #007bff;
            color: white;
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            font-size: 18px; /* Giảm kích thước font chữ tiêu đề */
        }

        .table {
            font-size: 12px; /* Giảm kích thước font chữ trong bảng */
        }

        .btn {
            font-size: 12px; /* Giảm kích thước font chữ trên các nút */
        }

        .btn-create {
            background-color: #28a745;
            color: white;
            padding: 8px 20px;
            border-radius: 5px;
            text-decoration: none;
        }

            .btn-create:hover {
                background-color: #218838;
            }

        .table-wrapper {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .table thead {
            background-color: #343a40;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f1f1f1;
        }

        .product-image {
            max-width: 100px;
            max-height: 100px;
            object-fit: cover;
        }

        .action-buttons a, .action-buttons form button {
            margin: 2px;
        }

        .sort-options {
            margin-top: 10px;
        }
    </style>
    <style>
        .message-box {
            margin: 20px auto; /* Tạo khoảng cách và căn giữa theo chiều ngang */
            padding: 15px;
            border-radius: 8px;
            font-size: 16px;
            text-align: center;
            max-width: 600px;
            width: auto;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        }

            .message-box.success {
                background-color: #d4edda;
                color: #155724;
                border: 1px solid #c3e6cb;
            }

            .message-box.error {
                background-color: #f8d7da;
                color: #721c24;
                border: 1px solid #f5c6cb;
            }


    </style>
</head>
<body>
    @if (ViewBag.SuccessMessage != null)
    {
        <div class="message-box success">
            @ViewBag.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="message-box error">
            @ViewBag.ErrorMessage
        </div>
    }

    <!-- Header -->
    <div class="container my-4">
        <h1 class="page-title">Danh Sách Sản Phẩm</h1>
    </div>

    <!-- Main Content -->
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4">Quản lý Sản Phẩm</h2>
            <a asp-action="formThemSanPham" class="btn btn-create">
                <i class="fas fa-plus"></i> Thêm Sản Phẩm
            </a>
        </div>

        <!-- Table -->
        <div class="table-wrapper">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead>
                        <tr>
                            <th class="text-center">Mã Sản Phẩm</th>
                            <th>Tên Sản Phẩm</th>
                            <th>Hình Ảnh</th>
                            <th class="text-end">Giá Bán (VNĐ)</th>
                            <th>Trạng Thái</th>
                            <th>Mô Tả</th>
                            <th class="text-center">Hàng Còn</th>
                            <th>Kích Cỡ</th>
                            <th>Loại Sản Phẩm</th>
                            <th>Thương Hiệu</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">@item.MaSp</td>
                                <td>@item.TenSp</td>
                                <td>
                                    <img src="@Url.Content("/HinhAnh/" + item.HinhAnh)" alt="Product Image" class="product-image">
                                </td>
                                <td class="text-end">
                                    @(item.GiaBan.HasValue ? ((decimal)item.GiaBan.Value).ToString("N0") : "N/A")đ
                                </td>

                                <td>@item.TrangThai</td>
                                <td>@item.MoTa</td>
                                <td class="text-center">   @(item.HangTonKho.HasValue ? ((decimal)item.HangTonKho.Value).ToString("N0") : "N/A")</td>
                                <td>@item.KichCo</td>
                                <td>@item.MaLoaiNavigation.TenLoai @item.MaLoaiNavigation.MaThNavigation.TenTh</td>
                                <td>@item.MaLoaiNavigation.MaThNavigation.TenTh</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <!-- View Details -->
                                        <a class="btn btn-info btn-sm" asp-action="xemChiTietSanPham" asp-route-id="@item.MaSp">
                                            <i class="fas fa-eye"></i> Chi Tiết
                                        </a>
                                        <!-- Delete -->
                                        <button onclick="xoaHangHoa('@item.MaSp')" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </button>


                                        <!-- Edit -->
                                        <form method="post" asp-action="formSuaSP" class="m-0">
                                            <input type="hidden" name="idsua" value="@item.MaSp" />
                                            <button type="submit" class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Sửa
                                            </button>
                                        </form>
                                    </div>
                                    <!-- Sorting Options -->

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script>
        function xoaHangHoa(id) {
            if (window.confirm("Bạn có thực sự muốn xoá hàng hoá \'" + id + "\'này không?") == false) {
                return;

            }
            // Create an XMLHttpRequest object
            const xhttp = new XMLHttpRequest();
            // Define a callback function
            // Here you can use the Data//code nay laf ham xu ly ket qua tra ve
            xhttp.onload = function () {
                if (JSON.parse(xhttp.responseText) == true)//Json.parse la doi dang chuoi sang kieu true false //con json.stringify la doi true false sang chuoi
                {
                    window.location.href = "/NhanVienQLSP/SanPham/";
                }
                else {
                    window.alert("Bi loi khi xoa");
                }
            }
            // Send a request
            var url = "/NhanVienQLSP/xoaHangHoa/" + id;//này là truyền lên sever( controller/nơi nhận) vaf la nơi đưa dử liệu lên svever
            xhttp.open("GET", url);
            xhttp.send()
        }
    </script>


    <!-- Footer -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>


</body>
</html>






