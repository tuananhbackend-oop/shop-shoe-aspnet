			<!-- Form Thanh toán khi nhận hàng -->
			<form id="form_cod" asp-action="themDonHang" asp-controller="User" method="post">
				<div class="mb-3">
					<label for="SoDienThoai" class="form-label">Số điện thoại</label>
					<input asp-for="SoDienThoai" class="form-control" id="SoDienThoai"
						   maxlength="10"
						   data-val="true"
						   data-val-length="Số điện thoại phải có chính xác 10 chữ số." />
					<span asp-validation-for="SoDienThoai" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<label for="TaiKhoan" class="form-label">Tài khoản</label>
					<input asp-for="TaiKhoan" class="form-control" id="TaiKhoan" type="email" />
					<span asp-validation-for="TaiKhoan" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<label for="DiaChi" class="form-label">Địa chỉ</label>
					<input asp-for="DiaChi" class="form-control" id="DiaChi" />
					<span asp-validation-for="DiaChi" class="text-danger"></span>
				</div>

				<div class="text-center">
					<button type="submit" class="btn btn-primary btn-lg" id="submitBtn">Đặt Đơn Hàng</button>
				</div>
			</form>

		

			<!-- Form Thanh toán bằng MoMo -->
			<form id="form_momo" style="display: none;" method="post" asp-action="CreatePaymentMoMo" asp-controller="Payment">
				<div class="mb-3">
					<label for="sodienthoai" class="form-label">Số điện thoại</label>
					<input asp-for="SoDienThoai" class="form-control" id="sodienthoai" name="sodienthoai" />
				</div>
				<div class="mb-3">
					<label for="FullName" class="form-label">Tài khoản</label>
					<input asp-for="TaiKhoan" class="form-control" id="Fullname" name="Fullname" type="email"/>
				</div>
				<div class="mb-3">
					<label for="OrderInformation" class="form-label">Địa chỉ</label>
					<input asp-for="DiaChi" class="form-control" id="OrderInformation" name="OrderInformation" />
				</div>
	
		
				<input type="hidden" name="Amount" value="@tongTien" />
				<div class="text-center">
					<button type="submit" class="btn btn-danger btn-lg">Thanh toán bằng MoMo</button>
				</div>
			</form>


			@{


				
				Random random = new Random();
				decimal ma = random.Next(00000, 99999); // Tạo số ngẫu nhiên từ 100 đến 999

			}
			<form id="form_vnpay" style="display: none;" method="post" asp-action="CreatePaymentUrlVnpay" asp-controller="Payment">
				<div class="mb-3">
					<label for="sodienthoai" class="form-label">Số điện thoại</label>
					<input asp-for="SoDienThoai" class="form-control" id="SoDienThoai" name="SoDienThoai" />
				</div>
			
					<input type="hidden" class="form-control" id="OrderId" name="OrderId" value="@ma"/>
				<div class="mb-3">
					<label for="Name" class="form-label">Tài khoản</label>
					<input asp-for="TaiKhoan" class="form-control" id="Name" name="Name" type="email" />
				</div>
				<div class="mb-3">
					<label for="OrderDescription" class="form-label">Địa chỉ</label>
					<input asp-for="DiaChi" class="form-control" id="OrderDescription" name="OrderDescription" />
				</div>
				<input type="hidden" name="Amount" value="@tongTien" />
				
				<input type="hidden" name="OrderType" value="order" />
				<div class="text-center">
					<button type="submit" class="btn btn-danger btn-lg custom-button">Thanh toán bằng Vnpay</button>
				</div>
			</form>

		<style>
				.custom-button {
					background-color: #003366; /* Màu xanh đậm */
					color: white; /* Chữ màu trắng */
					border: none; /* Loại bỏ viền (nếu cần) */
					transition: none; /* Tắt hiệu ứng chuyển đổi */
				}

					.custom-button:hover {
						background-color: #003366; /* Giữ nguyên màu nền khi hover */
						color: white; /* Giữ nguyên màu chữ */
					}
		</style>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		// JS để xử lý hiển thị form dựa trên phương thức thanh toán được chọn
		document.addEventListener('DOMContentLoaded', function () {
			const formCod = document.getElementById('form_cod');
			const formMomo = document.getElementById('form_momo');
			const formVnpay = document.getElementById('form_vnpay');
			const paymentMethods = document.getElementsByName('payment_method');

			paymentMethods.forEach(method => {
				method.addEventListener('change', function () {
					if (this.value === 'cod') {
						formCod.style.display = 'block';
						formMomo.style.display = 'none';
						formVnpay.style.display = 'none';
					} else if (this.value === 'momo') {
						formCod.style.display = 'none';
						formMomo.style.display = 'block';
						formVnpay.style.display = 'none';
					} else if (this.value === 'vnpay') {
						formCod.style.display = 'none';
						formMomo.style.display = 'none';
						formVnpay.style.display = 'block';
					}
				});
			});

			// Hiển thị form mặc định dựa trên giá trị đã chọn
			const selectedMethod = document.querySelector('input[name="payment_method"]:checked');
			if (selectedMethod) {
				selectedMethod.dispatchEvent(new Event('change'));
			}
		});
	</script>

	<script>
		// JavaScript để kiểm tra số điện thoại
		document.getElementById("form_cod").onsubmit = function (e) {
			var soDienThoai = document.getElementById("SoDienThoai").value;
			var regex = /^\d{10}$/;
			if (!regex.test(soDienThoai)) {
				e.preventDefault();  // Ngừng việc gửi form
				alert("Số điện thoại phải có đúng 10 chữ số.");
			}
		}
	</script>
	<script>
		// JavaScript để kiểm tra số điện thoại
		document.getElementById("form_momo").onsubmit = function (e) {
			var sodienthoai = document.getElementById("sodienthoai").value;
			var regex = /^\d{10}$/;
			if (!regex.test(sodienthoai)) {
				e.preventDefault();  // Ngừng việc gửi form
				alert("Số điện thoại phải có đúng 10 chữ số.");
			}
		}
	</script>
	
</body>

</html>


