<body class="template_cart" id="ega-fashion">

	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const SuccessMessagesaitk = '@Html.Raw(ViewData["SuccessMessagesaitk"])'; 
			if (SuccessMessagesaitk) {
				alert(SuccessMessagesaitk);
			}
		});
	</script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const successMessage = '@Html.Raw(ViewData["SuccessMessage"])';
			if (successMessage) {
				alert(successMessage);
			}
		});
	</script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const ErrorMessage = '@Html.Raw(ViewData["ErrorMessage"])';
			if (ErrorMessage) {
				alert(ErrorMessage);
			}
		});
	</script>

	<div class="ega-cart" id="ega-cart">
		<div class="ega-container">
			
				<div class="ega-cart__wrap">
					<div class="ega-cart-content">
				
						<div class="cart-body-left">
						<div class="ega-cart-head ega-hidden--sm ega-hidden--xs">
							<div class="ega-row">
								<div class="ega-col-md-1"></div>
								<div class="ega-col-md-11">
									<div class="ega-row">
										<div class="ega-col-5" style="color: black;">Sản phẩm</div>
										<div class="ega-col-2" style="color: black;">Đơn giá</div>
										<div class="ega-col-3" style="color: black;">Số lượng</div>
										<div class="ega-col-2" style="color: black;">Thành tiền</div>
									</div>
								</div>
							</div>
						</div>
				
						@{
							int tongTien = 0;
						}
						@foreach (var item in Model.ChiTietDonHangs)
						{
							<div class="ega-cart-body">
								<div class="ega-row ega-cart-row">
									<div class="ega-col-md-1 ega-col-2 ega-text--right">
										<form asp-action="xoaGioHang" method="post">
											<input type="hidden" name="xoagh" value="@item.MaSp" />
											<button type="submit" class="">
												<i class="fa fa-trash" style="color: black;"></i> <!-- Icon thùng rác từ FontAwesome -->
											</button>
										</form>
									</div>



									<div class="ega-col-md-11 ega-col-10">
										<div class="ega-row ega-cart-info">
											<div class="ega-col-md-2 ega-col-12 ega-cart-img">



												<a class="ega-d--block" href="/products/joma-top-flex-pito-tf-2462-trang-hong">
													<img width="150" src="@Url.Content("/HinhAnh/"+item.MaSpNavigation.HinhAnh)"/>
												</a>
											</div>
											<div class="ega-col-md-3 ega-col-12">
											<h5 class="cart-pd-title">@item.MaSpNavigation.TenSp</h5>
												<div class="cart-variant">
													
													<span>@item.MaSpNavigation.KichCo</span>
												</div>
											</div>
											<div class="ega-col-md-2 ega-col-12">
												<span class="cart-item-price" style="color: black;">
													@(item.MaSpNavigation.GiaBan.HasValue ? ((decimal)item.MaSpNavigation.GiaBan.Value).ToString("N0") : "N/A")đ
												</span>
											</div>

											<div class="ega-col-md-3 ega-col-12">
												<div class="ega-d--flex ega-cart-quantity" data-ega-role="qty-wrapper" style="color: black;">
													@item.SoLuong
												</div>
											</div>

											<div class="ega-col-md-2 ega-col-12 ega-hidden--sm ega-hidden--xs">
												<span class="line-item-total" style="color: black;">
												
													@(item.MaSpNavigation.GiaBan.HasValue ? ((decimal)(item.SoLuong * item.MaSpNavigation.GiaBan.Value)).ToString("N0") : "N/A")đ
												</span>
											</div>
											

										</div>
									</div>
								</div>
							</div>
							tongTien += (int)(item.SoLuong * item.MaSpNavigation.GiaBan.Value);
						}
					</div>
					<div class="ega-cart-total">
						<div class="ega-cart-total__content">
							<span class="total-label">Tổng thanh toán:</span>
							<span class="total-amount">@tongTien.ToString("N0")đ</span>
						</div>
					</div>
					
						
						
			
				</div>
			</div>
			
		</div>
