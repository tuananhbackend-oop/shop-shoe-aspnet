		}

		/* Tùy chỉnh phần danh sách giá */
		.ega-price-list {
			list-style-type: none;
			padding: 0;
			margin: 0;
		}

		.ega-price-item {
			display: block;
			padding: 12px 16px; /* Padding phải */
			color: #666; /* Màu chữ đen nhạt */
			text-decoration: none;
			border: 2px solid #ccc; /* Màu khung xám nhạt */
			border-radius: 5px;
			margin-bottom: 10px;
			transition: all 0.3s ease;
			font-size: 16px;
		}

			.ega-price-item:hover {
				background-color: #f0f0f0; /* Màu nền sáng khi hover */
				color: #333; /* Màu chữ đậm khi hover */
			}

			.ega-price-item:active {
				background-color: #e0e0e0; /* Màu nền sáng hơn khi nhấn */
			}

			.ega-price-item:last-child {
				margin-bottom: 0;
			}

	</style>
	<style>
		#ega-collection .ega-filter__title {
			font-weight: bold;
			font-size: 16px;
			color: #0E1C22;
			position: relative;
			line-height: inherit;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: space-between;
		}

			#ega-collection .ega-filter__title svg path {
				fill: #fff;
			}

			#ega-collection .ega-filter__title svg {
				right: 10px;
				font-size: 24px;
				fill: #fff;
			}

		.is-show h4 svg {
			transform: rotate(180deg);
		}
	</style>
	<style>
		.product-image {
			position: relative;
			width: 100%; /* Chiếm toàn bộ chiều rộng phần tử cha */
			height: 167px; /* Chiều cao cố định cho container */
		}

			.product-image img {
				width: 100%; /* Hình ảnh chiếm toàn bộ chiều rộng */
				height: 100%; /* Chiều cao bằng với container */
				object-fit: cover; /* Đảm bảo hình ảnh không bị méo */
			}

			.product-image span {
				position: absolute;
				top: 0;
				right: 0;
				background-color: red; /* Nền đỏ cho dòng chữ */
				color: white; /* Màu chữ trắng */
				padding: 5px 10px;
				font-size: 14px;
				font-weight: bold;
				border-radius: 5px;
			}

	</style>

</head>
<body class="template_collection" id="ega-fashion">
	<div class="riccusedi" id="ega-collection">
		<div class="ega-container">
			<input id="collection_id" type="hidden" value="=1004240769">
			<div class="collection-wrapper">
				<div class="ega-row">
					<div class="ega-col-xl-3 ega-col-lg-12 ega-col-12 ">
						<div id="collection_sidebar">
							<div class="sidebar-widgets-wrap">
								<div class="ega-filter" data-style="ega-filter">
									<div class="ega-filter__heading">
										<h4 class="ega-filter__title ega-h6 ega-m--0">BỘ LỌC<svg xmlns="http://www.w3.org/2000/svg" class="ega-ic-close"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ega-ic-close" /></svg></h4>
									</div>

									<div class="ega-filter__body">
										=


										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />
										<br />

										<div class="new">
											<h4 class="ega-filter__title ega-h6 ega-m--0" id="price-title">GIÁ</h4>
											<ul class="ega-price-list">
												@foreach (var gia in new List<string> { "Dưới 1.000.000đ", "1.000.000đ - 2.000.000đ", "2.000.000đ - 3.000.000đ", "3.000.000đ - 4.000.000đ", "Trên 4.000.000đ" })
												{
													<li>
														<a class="ega-price-item" href="@Url.Action("hienThiSanPhamTheoGia", "User", new { gia = gia })">
															@gia
														</a>
													</li>

												}
											</ul>
										</div>


										<div>
											<br />
										</div>

										<div class="ega-filter__item is-show">
											<h4 class="ega-filter__title ega-h6 ega-m--0">SIZE</h4>
											<div class="ega-filter__sizes">
												<ul class="ega-size-list">
													@foreach (var size in new List<string> { "39", "40", "41", "42", "43", "44" })
													{
														<li>
															<a href="@Url.Action("HienThiSanPhamTheoSize", "User", new { size = size })">
																@size
															</a>
														</li>
													}
												</ul>
											</div>
										</div>





										<!-- BEGIN: Tag_Custom_1 filter -->
										<!-- END: Tag_Custom_7 filter -->


									</div>
								</div>









							</div>
						</div>

					</div>
					<div class="ega-col-xl-9 ega-col-lg-12 ega-col-12">
						<div class="collection_banner ega-m-b--4 hover-zoom">
						</div>



						<h1 id="ega-coll-name">DANH MỤC SẢN PHẨM</h1>

						<div class="des"><p style="text-align: justify;"><span style="font-size: 16px;">Chọn một đôi giày đá bóng thích hợp sẽ giúp bạn tự tin thể hiện hết khả năng mỗi khi ra sân. Và để xác định đúng “chân ái” dành riêng cho bạn, có 3 yếu tố tiên quyết bạn nên cân nhắc: mặt sân thi đấu (sân sàn hay sân cỏ nhân tạo), form chân (chân thon hay bè) và mức giá mong muốn.</span></p><p><p style="text-align: justify;"><span style="font-size: 16px;">Tại Thanh Hùng Futsal, chúng mình đang có sẵn những mẫu Giày Đá Bóng Cỏ Nhân Tạo và Giày Futsal mới và hot nhất đến từ 10 thương hiệu thể thao hàng đầu trong nước và quốc tế, bao gồm các thương hiệu hàng đầu hiện nay như Nike, adidas, PUMA, Mizuno, Joma, Asics...Cùng với đó là các Phụ Kiện Ra Sân tiện lợi như vớ, túi đựng giày, trái bóng,...</span></p><p></p></div>
						<div id="sort-wrap">
							<div class="sort-left count-products">


								<div class="tagsoredu">
								</div>
							</div>


							<div class="sort-right ega-text--right">
								<div class="ega-sortby">

									<div class="sortby__wrap">
										<select data-role="sortby" onchange="window.location.href=this.value;">
											<option value="@Url.Action("SanPham", "User", new { sortOrder = "manual" })"> Tất cả sản phẩm </option>
											<option value="@Url.Action("sanPhamMoi", "User", new { sortOrder = "manual" })"> Sản phẩm mới </option>
											<option value="@Url.Action("sapXepSanPham", "User", new { sortOrder = "price_asc" })">Giá: tăng dần</option>
											<option value="@Url.Action("sapXepSanPham", "User", new { sortOrder = "price_desc" })">Giá: giảm dần</option>
										</select>


									</div>
								</div>

								<div class="filter-on-mb">
									<div class="filter-open">
										<span>Lọc sản phẩm</span><svg xmlns="http://www.w3.org/2000/svg" class="ega-ic-angle-down"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ega-ic-angle-down" /></svg>
									</div>
								</div>
							</div>
						</div>


						<div class="fulldataa">
							<div id="result">
								<div class="ega-row">
									@foreach (var item in Model.GroupBy(m => m.TenSp).Select(g => g.First()))
									{
										if (item.NgayThemSP != null)
										{
											var today = DateTime.Now;
											var daysDifference = (today - item.NgayThemSP.Value).Days;
											if (daysDifference <= 30)
											{
												<div class="ega-col-lg-3 ega-col-md-4 ega-col-6">
													<div class="product-wrapper">
														<!-- Hình ảnh sản phẩm -->

														<div class="product-image">
															<img width="480" height="100" class="lazyload" src="@Url.Content("/HinhAnh/" + item.HinhAnh)">
															<span>MỚI RA MẮT</span>
														</div>

														<!-- Tiêu đề sản phẩm -->
														<h2 class="product-title">
															@item.MaLoaiNavigation.TenLoai @item.MaLoaiNavigation.MaThNavigation.TenTh @item.TenSp - @item.KichCo
														</h2>

														<!-- Size giày -->
														<!-- Giá -->
														<div class="product-price">
															@(item.GiaBan.HasValue ? ((decimal)item.GiaBan.Value).ToString("N0") : "N/A") đ
														</div>


														<!-- Thông tin Fundiin -->
														<!-- Nút xem chi tiết -->
														<form asp-action="chiTietSP" method="post">
															<input type="hidden" name="MaSp" value="@item.MaSp">
															<button type="submit" class="view-details-btn">Xem Chi Tiết</button>
														</form>
													</div>

												</div>
											}
										}

									}
									@* 	Sản phẩm cũ *@
									@foreach (var item in Model.GroupBy(m => m.TenSp).Select(g => g.First()))
									{
										if (item.NgayThemSP != null)
										{
											var today = DateTime.Now;
											var daysDifference = (today - item.NgayThemSP.Value).Days;
											if (daysDifference > 30)
											{
												<div class="ega-col-lg-3 ega-col-md-4 ega-col-6">
													<div class="product-wrapper">
														<!-- Hình ảnh sản phẩm -->

														<div class="product-image">
															<img width="480" height="100" class="lazyload" src="@Url.Content("/HinhAnh/" + item.HinhAnh)">

														</div>

														<!-- Tiêu đề sản phẩm -->
														<h2 class="product-title">
															@item.MaLoaiNavigation.TenLoai @item.MaLoaiNavigation.MaThNavigation.TenTh @item.TenSp - @item.KichCo
														</h2>

														<!-- Size giày -->
														<!-- Giá -->
														<div class="product-price">
															@(item.GiaBan.HasValue ? ((decimal)item.GiaBan.Value).ToString("N0") : "N/A") đ
														</div>
														<!-- Nút xem chi tiết -->
														<form asp-action="chiTietSP" method="post">
															<input type="hidden" name="MaSp" value="@item.MaSp">
															<button type="submit" class="view-details-btn">Xem Chi Tiết</button>
														</form>
													</div>

												</div>
											}
										}

									}

								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<style>
		/* Điều chỉnh width cho các cột */
		.ega-col-xl-9, .ega-col-lg-12, .ega-col-12 {
			width: 300%; /* Hoặc bạn có thể dùng một phần trăm lớn hơn để mở rộng */
		}

		/* Cập nhật để sử dụng flex */
		/* Đảm bảo các cột được sắp xếp linh hoạt và có thể xuống dòng */
		.ega-row {
			width: 100%; /* Đảm bảo container bao quanh chiếm toàn bộ chiều rộng */
			display: flex !important;
			flex-wrap: wrap !important;
			gap: 0px !important;
		}

		.ega-col-lg-3, .ega-col-md-4, .ega-col-6 {
			padding: 2px !important; /* Thêm padding nhẹ bên trong mỗi cột */
			margin: 0 !important;
			width: auto !important;
			flex: 1 0 auto !important;
			box-sizing: border-box; /* Đảm bảo padding không làm tăng kích thước cột */
		}


			/* Đảm bảo cột đầu tiên không có margin trái */
			.ega-col-lg-3:first-child, .ega-col-md-4:first-child, .ega-col-6:first-child {
				margin-left: 0;
			}

			/* Đảm bảo cột cuối cùng không có margin phải */
			.ega-col-lg-3:last-child, .ega-col-md-4:last-child, .ega-col-6:last-child {
				margin-right: 0;
			}


		/* Điều chỉnh padding để các cột hẹp nhất có thể */

		.product-wrapper {
			display: flex; /* Đảm bảo nội dung bên trong sắp xếp linh hoạt */
			flex-direction: column; /* Xếp chồng các phần tử con theo chiều dọc */
			align-items: center; /* Căn giữa các phần tử theo trục ngang */
			justify-content: space-between; /* Khoảng cách đều giữa các phần tử */
			padding: 1px; /* Tăng khoảng cách bên trong một chút */
			margin: 1px; /* Tạo khoảng cách nhỏ giữa các sản phẩm */
			box-sizing: border-box; /* Đảm bảo padding không làm thay đổi kích thước */
			overflow: hidden; /* Ẩn phần nội dung tràn ra ngoài */
			background-color: #fff; /* Đặt nền trắng hoặc màu khác tùy ý */
			border: 1px solid #ddd; /* Tạo viền nhẹ cho sản phẩm */
			border-radius: 5px; /* Làm mềm góc các sản phẩm */
		}

			.product-wrapper img {
				max-width: 100%; /* Hình ảnh không vượt quá kích thước của container */
				height: auto; /* Đảm bảo tỉ lệ hình ảnh */
				object-fit: cover; /* Làm đầy khung mà không méo ảnh */
			}

		.product-title {
			font-size: 14px; /* Giảm kích thước chữ để vừa với container */

			overflow: hidden; /* Ẩn phần chữ thừa */
			text-overflow: ellipsis; /* Thêm dấu '...' nếu chữ quá dài */
			text-align: center; /* Căn giữa tiêu đề */
		}

		.product-price {
			font-size: 16px;
			font-weight: bold;
			color: #333;
			margin: 5px 0; /* Tạo khoảng cách trên dưới */
		}

		.fundiin-info {
			font-size: 12px;
			text-align: center;
			color: #24c3fd;
		}

		.ega-col-lg-3 .product-wrapper,
		.ega-col-md-4 .product-wrapper,
		.ega-col-6 .product-wrapper {
			height: 100%; /* Đảm bảo chiều cao của mỗi cột đồng nhất */
		}
	</style>
	<script>
		$(function () {
			setTimeout(function () {
				$("select[data-role='sortby']").val('manual');
			})
