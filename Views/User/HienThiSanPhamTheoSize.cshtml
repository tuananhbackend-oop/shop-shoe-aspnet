	<style>
		/* CSS chỉnh sửa */
		.product-wrapper {
			display: flex;
			flex-direction: column;
			justify-content: space-between;
			align-items: center; /* Đảm bảo mọi phần tử căn giữa */
			padding: 10px; /* Giảm padding */
			background-color: #ffffff;
			border: 1px solid #ddd;
			border-radius: 8px;
			transition: all 0.3s ease;
			text-align: center;
			height: 100%;
			box-sizing: border-box;
			gap: 8px; /* Khoảng cách giữa các phần tử */
		}

		.product-image {
			position: relative;
			overflow: hidden;
			border-radius: 8px;
		}

			.product-image img {
				width: 100%;
				height: auto;
				object-fit: cover;
				transition: transform 0.3s ease;
			}

		.product-wrapper:hover .product-image img {
			transform: scale(1.05);
		}

		.product-title {
			font-size: 18px; /* Tăng kích thước */
			font-weight: bold; /* Đậm hơn */
			color: #2c3e50; /* Màu chữ dễ nhìn */
			margin: 0; /* Xóa margin mặc định */
			line-height: 1.5;
			text-align: center;
			font-family: 'Arial', sans-serif; /* Font chữ phổ biến */
		}

		.product-price {
			font-size: 16px; /* Giảm kích thước */
			font-weight: 600;
			color: #e74c3c;
			margin: 0;
		}

		.fundiin-info {
			font-size: 13px; /* Giảm font size */
