		})
	</script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const SuccessMessagehetSP = '@Html.Raw(ViewData["SuccessMessagehetSP"])';
			if (SuccessMessagehetSP) {
				alert(SuccessMessagehetSP);
			}
		});
	</script>

</body>
