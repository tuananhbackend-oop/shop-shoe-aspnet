			margin: 5px 0; /* Giảm khoảng cách */
		}

		.view-details-btn {
			padding: 8px 16px; /* Giảm kích thước nút */
			font-size: 14px;
			font-weight: 600;
			color: #fff;
			background-color: #3498db;
			border: none;
			border-radius: 4px;
			cursor: pointer;
			transition: background-color 0.3s ease;
			text-transform: uppercase;
		}

			.view-details-btn:hover {
