	<script>
		// Xử lý sự kiện tăng/giảm số lượng
		document.querySelectorAll('.quantity-wrapper').forEach(function (wrapper) {
			const input = wrapper.querySelector('.quantity-input');
			const minusBtn = wrapper.querySelector('.minus');
			const plusBtn = wrapper.querySelector('.plus');

			// Sự kiện khi nhấn nút cộng (+)
			plusBtn.addEventListener('click', function () {
				input.value = parseInt(input.value) + 1;
			});

			// Sự kiện khi nhấn nút trừ (-)
			minusBtn.addEventListener('click', function () {
				if (parseInt(input.value) > 0) {
					input.value = parseInt(input.value) - 1;
				}
			});

			// Xử lý nhập giá trị trực tiếp
			input.addEventListener('input', function () {
				if (parseInt(input.value) < 0 || isNaN(input.value)) {
					input.value = 0; // Không cho phép giá trị âm
				}
			});
		});

	</script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			// Lấy tất cả các hàng có .quantity-wrapper
			document.querySelectorAll(".quantity-wrapper").forEach((wrapper) => {
				const input = wrapper.querySelector(".quantity-input");
				const minusButton = wrapper.querySelector(".btn-quantity.minus");
				const plusButton = wrapper.querySelector(".btn-quantity.plus");
				const max = parseInt(input.dataset.max);

				// Đặt giá trị mặc định là max nếu vượt quá max
				if (parseInt(input.value) > max) {
					input.value = max - 1;
				}

				// Xử lý nút giảm
				minusButton.addEventListener("click", function (event) {
					event.preventDefault(); // Ngăn sự kiện mặc định
					const currentValue = parseInt(input.value) || 0;
					const min = parseInt(input.min) || 0;

					if (currentValue > min) {
						input.value = currentValue; // Giảm 1
					}
				});

				// Xử lý nút tăng
				plusButton.addEventListener("click", function (event) {
					event.preventDefault(); // Ngăn sự kiện mặc định
					const currentValue = parseInt(input.value) || 0;

					if (currentValue < max) {
						input.value = currentValue; // Tăng 1
					} else {
						alert(`Số lượng không được vượt quá ${max}`);
						input.value = max; // Đặt về max nếu vượt
					}
				});

				// Kiểm tra khi nhập giá trị trực tiếp
				input.addEventListener("input", function () {
					let value = parseInt(this.value) || 0;

					if (value > max) {
						alert(`Số lượng không được vượt quá ${max}`);
						this.value = max; // Đặt về max nếu vượt
					} else if (value < 0) {
						this.value = 0; // Đặt về 0 nếu nhỏ hơn 0
					}
				});
			});
		});






	</script>
</body>
