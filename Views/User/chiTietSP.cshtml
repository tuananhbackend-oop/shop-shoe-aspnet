@model LVTNWEBGIAYDEP.Models.SanPham
@using Microsoft.EntityFrameworkCore;
@using LVTNWEBGIAYDEP.Models
@using Microsoft.EntityFrameworkCore 
@inject DBGiayDepContext db
@{
    ViewData["Title"] = "chiTietSP";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
@{
	
	var ten = TempData["TenSanPham"] as string; // Lấy tên sản phẩm từ TempData


		// Lấy danh sách sản phẩm theo tên
		var Sanp = db.SanPhams.Include(sp => sp.MaLoaiNavigation)
									.ThenInclude(sp1 => sp1.MaThNavigation)
									.Where(t => t.TenSp == ten)
									.ToList();			
}


